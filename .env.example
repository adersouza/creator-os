# Creator OS — environment template. Copy to `.env` and fill in.
# Vars are read across the Python packages and apps/contentforge. Path-root vars
# have sensible defaults (see campaign_factory/config.py) and only need setting if
# your checkout layout differs. Required vars have no safe default.

# ── Required: Supabase (data + storage) ───────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_STORAGE_BUCKET=
# Front-end (contentforge / Vite) copy:
VITE_SUPABASE_URL=
# Legacy aliases still honored by some entry points (prefer the vars above):
# SUPABASE_SERVICE_KEY=
# NEXT_PUBLIC_SUPABASE_URL=

# ── Required: model providers ─────────────────────────────────────────────────
# Gemini/Google (one of these) drives semantic generation; Grok/XAI optional.
GEMINI_API_KEY=
GOOGLE_API_KEY=
GROK_API_KEY=
XAI_API_KEY=

# ── Required: local API auth + ingest secrets ─────────────────────────────────
# Shared token guarding the local campaign/reel FastAPI services.
CREATOR_OS_API_TOKEN=
# HMAC-SHA256 key used by Campaign Factory to sign ThreadsDashboard draft ingest.
# Generate at least 32 random bytes; the raw key is never sent over HTTP.
CAMPAIGN_FACTORY_INGEST_SECRET=

# ── Cross-service integration URLs ────────────────────────────────────────────
CONTENTFORGE_BASE_URL=http://localhost:3002
# Reel GUI status API URL used by Command Center/ContentForge dashboards.
# REEL_GUI_URL=http://127.0.0.1:8765
CAMPAIGN_FACTORY_DRAFT_INGEST_URL=
THREADSDASH_CAMPAIGN_FACTORY_INGEST_URL=
THREADSDASH_ALLOWED_INGEST_HOSTS=
THREADSDASH_USER_ID=
# REDIS_URL=redis://localhost:6379

# ── Path roots (override only for a non-standard layout) ──────────────────────
# Defaults assume the standard monorepo + a sibling ThreadsDashboard checkout.
# CREATOR_OS_ROOT=
# CAMPAIGN_FACTORY_ROOT=
# REEL_FACTORY_ROOT=
# REFERENCE_FACTORY_ROOT=
# CONTENTFORGE_ROOT=
# THREADSDASH_ROOT=
# REFERENCE_REELS_ROOT=
# CAMPAIGN_REFERENCE_BANK=
# REFERENCE_FACTORY_DATA_ROOT=   # default: ~/Developer/reference_reels
# CAMPAIGN_FACTORY_DB=           # sqlite path override
# CAMPAIGN_FACTORY_CAMPAIGNS=    # campaigns dir override
# CONTENTFORGE_RUNS_DIR=
# CONTENTFORGE_AUDIT_FEEDBACK_DIR=
# CONTENTFORGE_AUDIT_HISTORY_DIR=
# CREATOR_OS_TD_SNAPSHOT=        # ThreadsDashboard snapshot path used by doctor/orchestrator

# ── Optional feature flags / tuning (defaults are safe) ───────────────────────
# CAMPAIGN_FACTORY_ENABLE_LEGACY_SUPABASE_WRITES=0
# CAMPAIGN_FACTORY_ALLOW_LOCAL_THREADSDASH_INGEST=0
# ALLOW_INSECURE_LOCAL=0
# HIGGSFIELD_PROMPT_PACK=
# HIGGSFIELD_DAILY_BUDGET_CREDITS=8
# HIGGSFIELD_RUN_MAX_ASSETS=2
# HIGGSFIELD_COHORT_MAX_CREDITS=150
# HIGGSFIELD_MIN_BALANCE_CREDITS=25
# Optional one-release compatibility conversion for legacy USD reports only.
# HIGGSFIELD_USD_PER_CREDIT=
# Deprecated compatibility policy names; paid Higgsfield runs must use credits.
# HIGGSFIELD_DAILY_BUDGET_USD=10
# HIGGSFIELD_MIN_BALANCE_USD=5
# CONTENTFORGE_PYTHON=python3
# CONTENTFORGE_OCR_ENGINE=
# CONTENTFORGE_SSCD_MODEL_PATH=
# SSCD_MODEL_PATH=               # alias honored by reel_factory/sscd_video.py
# CONTENTFORGE_REAL_SAMPLE_MANIFEST=  # real media manifest for ContentForge local audits
# CREATOR_OS_PROACTIVE_CYCLE_DISABLED=0
# CREATOR_OS_ORCHESTRATOR_DISABLED=0
# LEARNING_LOOP_CUTOVER=         # ISO timestamp gating the learning-loop cutover
# LEARNING_FANOUT_MAX_ATTEMPTS=3
# REEL_FACTORY_LOCAL_NEXT_BATCH_ONLY=0
# REEL_FACTORY_CAMPAIGN_FACTORY_TIMEOUT_SECONDS=30
# REEL_FACTORY_IDENTITY_REFERENCE_SET=   # path to identity reference set for verification
# REEL_FACTORY_ENV=local         # local/test/prod marker for deprecated-generator guards
# REEL_FACTORY_ALLOW_DEPRECATED_GENERATORS=0  # allow legacy generators only for local migration review
# REEL_FACTORY_RAISE_ON_DEPRECATED_GENERATORS=0  # raise instead of warning on deprecated generator use
# CAMPAIGN_FACTORY_AUDIO_FIT=0
# REFERENCE_LABEL_WEIGHT_GOLD=
# REFERENCE_LABEL_WEIGHT_MAYBE=
# REFERENCE_LABEL_WEIGHT_IGNORE=
# REFERENCE_LABEL_WEIGHT_UNLABELED=
# CONTENTFORGE_MAX_UPLOAD_BYTES=
# CONTENTFORGE_VARIANT_PACK_CONCURRENCY=
# CONTENTFORGE_VARIANT_PACK_MAX_RETRIES=
# CONTENTFORGE_VARIANT_PACK_TIMEOUT_SECONDS=
# CONTENTFORGE_VARIANT_PACK_POLL_INTERVAL_SECONDS=
# CONTENTFORGE_ASSUME_DRAWTEXT=0
# CONTENTFORGE_DEBUG_OCR_BOXES=0
# CONTENTFORGE_APPLE_VISION_SCRIPT=
# CREATOR_OS_UI_PROOF=           # default UI-proof artifact path for scripts/doctor.py

# ── Runtime-provided environment names (documented only; do not set locally) ─
# APP_ENV=                       # provided by hosting/runtime; read by prod guards
# ENV=                           # provided by hosting/runtime; read by prod guards
# NODE_ENV=                      # provided by Node/Vercel; read by frontend/tooling
# VERCEL_ENV=                    # provided by Vercel; read by prod guards
