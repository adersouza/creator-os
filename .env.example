# Creator OS — environment template. Copy to `.env` and fill in.
# Vars are read across the Python packages and apps/contentforge. Path-root vars
# have sensible defaults (see campaign_factory/config.py) and only need setting if
# your checkout layout differs. Required vars have no safe default.

# ── Required: Supabase (data + storage) ───────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_STORAGE_BUCKET=
# Front-end (contentforge / Vite) copy:
VITE_SUPABASE_URL=

# ── Required: model providers ─────────────────────────────────────────────────
# Gemini/Google (one of these) drives semantic generation; Grok/XAI optional.
GEMINI_API_KEY=
GOOGLE_API_KEY=
GROK_API_KEY=
XAI_API_KEY=

# ── Required: local API auth + ingest secrets ─────────────────────────────────
# Shared token guarding the local campaign/reel FastAPI services.
CREATOR_OS_API_TOKEN=
# HMAC secret for ThreadsDashboard → Campaign Factory draft ingest.
CAMPAIGN_FACTORY_INGEST_SECRET=

# ── Cross-service integration URLs ────────────────────────────────────────────
CONTENTFORGE_BASE_URL=http://localhost:3002
CONTENTFORGE_URL=http://localhost:3002
CAMPAIGN_FACTORY_DRAFT_INGEST_URL=
THREADSDASH_CAMPAIGN_FACTORY_INGEST_URL=
THREADSDASH_ALLOWED_INGEST_HOSTS=
THREADSDASH_USER_ID=
# REDIS_URL=redis://localhost:6379

# ── Path roots (override only for a non-standard layout) ──────────────────────
# Defaults assume the standard monorepo + a sibling ThreadsDashboard checkout.
# CREATOR_OS_ROOT=
# CAMPAIGN_FACTORY_ROOT=
# REEL_FACTORY_ROOT=
# REFERENCE_FACTORY_ROOT=
# CONTENTFORGE_ROOT=
# THREADSDASH_ROOT=
# REFERENCE_REELS_ROOT=
# CAMPAIGN_REFERENCE_BANK=

# ── Optional feature flags / tuning (defaults are safe) ───────────────────────
# CAMPAIGN_FACTORY_ENABLE_LEGACY_SUPABASE_WRITES=0
# CAMPAIGN_FACTORY_ALLOW_LOCAL_THREADSDASH_INGEST=0
# ALLOW_INSECURE_LOCAL=0
# HIGGSFIELD_PROMPT_PACK=
# CONTENTFORGE_PYTHON=python3
# CONTENTFORGE_OCR_ENGINE=
# CONTENTFORGE_SSCD_MODEL_PATH=
