#!/usr/bin/env python3
"""Single operator-facing command for the headless Creator OS monorepo."""

from __future__ import annotations

import argparse
import math
import subprocess
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]


def _run(command: list[str], *, cwd: Path = ROOT) -> int:
    return subprocess.run(command, cwd=cwd, check=False).returncode


def _campaign_command(*args: str) -> list[str]:
    return ["uv", "run", "--package", "campaign-factory", "campaign-factory", *args]


def _reference_command(*args: str) -> list[str]:
    return [
        "uv",
        "run",
        "--package",
        "reference-factory",
        "python",
        "-m",
        "reference_factory.cli",
        *args,
    ]


def _reel_command(*args: str) -> list[str]:
    return [
        "uv",
        "run",
        "--package",
        "reel-factory",
        "python",
        "-m",
        "reel_factory.local_model_manager",
        *args,
    ]


def _local_queue_command(*args: str) -> list[str]:
    return [
        "uv",
        "run",
        "--package",
        "reel-factory",
        "python",
        "-m",
        "reel_factory.local_generation_queue",
        *args,
    ]


def _local_benchmark_command(*args: str) -> list[str]:
    return [
        "uv",
        "run",
        "--package",
        "reel-factory",
        "python",
        "-m",
        "reel_factory.local_model_benchmark",
        *args,
    ]


def _parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="creator-os",
        description="Operate Creator OS through one explicit, headless command surface.",
    )
    sub = parser.add_subparsers(dest="command", required=True)

    status = sub.add_parser(
        "status", help="read-only live configuration/runtime status"
    )
    status.add_argument("--json", action="store_true")
    status.add_argument(
        "--live-read-only",
        action="store_true",
        help="run configured zero-write network/provider probes",
    )

    doctor = sub.add_parser("doctor", help="read-only fixture-backed integrity audit")
    doctor.add_argument("args", nargs=argparse.REMAINDER)

    sync = sub.add_parser(
        "performance-sync",
        help="preview or apply the pinned ThreadsDashboard metrics/learning sync",
    )
    sync_mode = sync.add_mutually_exclusive_group(required=True)
    sync_mode.add_argument("--dry-run", action="store_true")
    sync_mode.add_argument("--apply", action="store_true")

    reference_refresh = sub.add_parser(
        "reference-refresh",
        help="preview or apply the local reference/audio refresh workflow",
    )
    reference_mode = reference_refresh.add_mutually_exclusive_group(required=True)
    reference_mode.add_argument("--dry-run", action="store_true")
    reference_mode.add_argument("--apply", action="store_true")
    reference_refresh.add_argument(
        "--source", type=Path, default=Path.home() / "Downloads/tiktok"
    )
    reference_refresh.add_argument(
        "--audio-export",
        type=Path,
        default=ROOT.parent / "reference_reels/audio_catalog.json",
    )

    generate = sub.add_parser(
        "generate",
        help="choose one explicit generation mode; use --list-modes for cost and gates",
    )
    generation_choice = generate.add_mutually_exclusive_group(required=True)
    generation_choice.add_argument("--mode")
    generation_choice.add_argument("--list-modes", action="store_true")
    generation_execution = generate.add_mutually_exclusive_group()
    generation_execution.add_argument("--dry-run", action="store_true")
    generation_execution.add_argument("--apply", action="store_true")
    generate.add_argument("--campaign")
    generate.add_argument("--reference-image", type=Path)
    generate.add_argument("--accepted-still", type=Path)
    generate.add_argument("--kling-selection-receipt", type=Path)
    generate.add_argument("--reference-video", type=Path)
    generate.add_argument("--target", help="creator identity/name")
    generate.add_argument("--soul-id")
    generate.add_argument("--workspace", type=Path)
    generate.add_argument("--confirm-paid", action="store_true")
    generate.add_argument("--max-credits", type=float)
    generate.add_argument("--max-usd", type=float)
    generate.add_argument("--caption")
    generate.add_argument("--duration", type=float)
    generate.add_argument("--motion-model")
    generate.add_argument(
        "--motion-task",
        choices=[
            "text_to_video",
            "image_to_video",
            "audio_image_to_video",
            "keyframe_interpolation",
        ],
        default="image_to_video",
    )
    generate.add_argument("--motion-prompt")
    generate.add_argument("--audio", type=Path)
    generate.add_argument("--generate-audio", action="store_true")
    generate.add_argument("--last-image", type=Path)
    generate.add_argument(
        "--motion-reference-image", type=Path, action="append", default=[]
    )
    generate.add_argument(
        "--motion-reference-video", type=Path, action="append", default=[]
    )
    generate.add_argument("--resolution")
    generate.add_argument("--seed", type=int, default=42)
    generate.add_argument("--steps", type=int)
    generate.add_argument("--enable-prompt-expansion", action="store_true")
    generate.add_argument("--shot-type", choices=["single", "multi"], default="single")
    generate.add_argument(
        "--local-model-dir", "--local-wan-model-dir", dest="local_model_dir", type=Path
    )
    generate.add_argument("--motion-lora", type=Path)
    generate.add_argument("--motion-lora-strength", type=float, default=1.0)
    generate.add_argument("--count", type=int, default=3)
    generate.add_argument("--account")
    generate.add_argument("--folder", type=Path)
    generate.add_argument("--model")
    generate.add_argument(
        "--format", choices=["reel", "slideshow", "auto"], default="auto"
    )
    generate.add_argument("--variant-count", type=int, default=20)
    generate.add_argument("--workers", type=int, default=3)
    generate.add_argument("--first-frame-approval-id")
    generate.add_argument("--last-frame-approval-id")
    generate.add_argument("--operator-selected", action="store_true")
    generate.add_argument("--rights-confirmed", action="store_true")
    generate.add_argument(
        "--preferred-provider", choices=["auto", "seedance", "kling"], default="auto"
    )
    generate.add_argument(
        "--available-provider",
        choices=["seedance", "kling"],
        action="append",
        default=[],
    )
    generate.add_argument("--allow-upscale", action="store_true")
    generate.add_argument("--wait", action="store_true")
    generate.add_argument("--download", action="store_true")

    readiness = sub.add_parser(
        "readiness", help="read-only Campaign Factory QC/readiness decision"
    )
    readiness.add_argument("--campaign", required=True)
    readiness.add_argument("--user-id")

    draft = sub.add_parser(
        "draft-export",
        help="preview or explicitly write validated drafts; never schedules or publishes",
    )
    draft_mode = draft.add_mutually_exclusive_group(required=True)
    draft_mode.add_argument("--dry-run", action="store_true")
    draft_mode.add_argument("--apply", action="store_true")
    draft.add_argument("--campaign", required=True)
    draft.add_argument("--user-id", required=True)
    draft.add_argument("--max-drafts", type=int, required=True)
    draft.add_argument("--rendered-asset-id", action="append", default=[])
    draft.add_argument(
        "--surface",
        choices=[
            "regular_reel",
            "trial_reel",
            "story",
            "story_cta",
            "feed_single",
            "feed_carousel",
        ],
        default="regular_reel",
        help="Export one explicit distribution surface (default: regular_reel)",
    )
    draft.add_argument("--review-only", action="store_true")

    local_models = sub.add_parser(
        "local-models", help="plan, install, or verify pinned local MLX video models"
    )
    local_models.add_argument("args", nargs=argparse.REMAINDER)

    local_queue = sub.add_parser(
        "local-queue",
        help="inspect the local generation lease journal or recover an interruption",
    )
    local_queue.add_argument("args", nargs=argparse.REMAINDER)

    local_benchmarks = sub.add_parser(
        "local-benchmarks",
        help="record measured QC-bound local results and explicitly promote models",
    )
    local_benchmarks.add_argument("args", nargs=argparse.REMAINDER)

    motion_qc_register = sub.add_parser(
        "motion-qc-register",
        help="register an immutable local motion-QC receipt; never publishes",
    )
    motion_qc_register.add_argument("--rendered-asset-id", required=True)
    motion_qc_register.add_argument("--receipt", type=Path, required=True)
    motion_qc_register.add_argument("--operator")

    return parser


def main(argv: list[str] | None = None) -> int:
    args = _parser().parse_args(argv)
    if args.command == "status":
        command = [sys.executable, str(ROOT / "scripts/doctor.py"), "--status"]
        if args.json:
            command.append("--json")
        if args.live_read_only:
            command.append("--live-read-only")
        return _run(command)
    if args.command == "doctor":
        doctor_args = args.args[1:] if args.args[:1] == ["--"] else args.args
        return _run([sys.executable, str(ROOT / "scripts/doctor.py"), *doctor_args])
    if args.command == "performance-sync":
        command = [str(ROOT / "scripts/run_threadsdash_performance_sync.sh")]
        if args.dry_run:
            command.append("--dry-run")
        return _run(command)
    if args.command == "reference-refresh":
        source = args.source.expanduser().resolve()
        audio_export = args.audio_export.expanduser().resolve()
        commands = [
            _reference_command("import-tiktok-archive", "--source", str(source)),
            _reference_command("refresh-tiktok-audio", "--source", str(source)),
            _reference_command("analyze-audio-patterns"),
            _reference_command("audio-health"),
            _reference_command("list-audio", "--export", str(audio_export)),
            _campaign_command("import-audio-catalog", "--path", str(audio_export)),
        ]
        if args.dry_run:
            for command in commands:
                print(" ".join(command))
            return 0
        for command in commands:
            if code := _run(command):
                return code
        return 0
    if args.command == "generate":
        if args.list_modes:
            return _run(_campaign_command("generation", "modes"))
        if not args.campaign:
            print("generate requires --campaign", file=sys.stderr)
            return 2
        if args.dry_run == args.apply:
            print(
                "generate requires exactly one of --dry-run or --apply", file=sys.stderr
            )
            return 2
        if args.max_credits is not None and (
            not math.isfinite(args.max_credits) or args.max_credits <= 0
        ):
            print("--max-credits must be finite and greater than zero", file=sys.stderr)
            return 2
        if args.max_usd is not None and (
            not math.isfinite(args.max_usd) or args.max_usd <= 0
        ):
            print("--max-usd must be finite and greater than zero", file=sys.stderr)
            return 2
        if args.duration is not None and (
            not math.isfinite(args.duration) or args.duration <= 0
        ):
            print("--duration must be finite and greater than zero", file=sys.stderr)
            return 2
        if args.count <= 0 or args.variant_count <= 0 or args.workers <= 0:
            print(
                "--count, --variant-count, and --workers must be greater than zero",
                file=sys.stderr,
            )
            return 2
        command = _campaign_command(
            "generation",
            "run",
            "--mode",
            args.mode,
            "--campaign",
            args.campaign,
            "--apply" if args.apply else "--dry-run",
        )
        optional_paths = (
            ("--reference-image", args.reference_image),
            ("--accepted-still", args.accepted_still),
            ("--kling-selection-receipt", args.kling_selection_receipt),
            ("--reference-video", args.reference_video),
            ("--workspace", args.workspace),
            ("--folder", args.folder),
            ("--audio", args.audio),
            ("--last-image", args.last_image),
            ("--local-model-dir", args.local_model_dir),
        )
        for flag, value in optional_paths:
            if value is not None:
                command.extend([flag, str(value.expanduser().resolve())])
        optional_values = (
            ("--target", args.target),
            ("--soul-id", args.soul_id),
            ("--max-credits", args.max_credits),
            ("--max-usd", args.max_usd),
            ("--caption", args.caption),
            ("--duration", args.duration),
            ("--account", args.account),
            ("--first-frame-approval-id", args.first_frame_approval_id),
            ("--last-frame-approval-id", args.last_frame_approval_id),
            ("--motion-model", args.motion_model),
            ("--motion-task", args.motion_task),
            ("--motion-prompt", args.motion_prompt),
            ("--resolution", args.resolution),
            ("--seed", args.seed),
            ("--steps", args.steps),
            ("--shot-type", args.shot_type),
            ("--motion-lora-strength", args.motion_lora_strength),
        )
        for flag, value in optional_values:
            if value is not None:
                command.extend([flag, str(value)])
        command.extend(["--count", str(args.count)])
        command.extend(["--variant-count", str(args.variant_count)])
        command.extend(["--workers", str(args.workers)])
        command.extend(["--format", args.format])
        if args.model:
            command.extend(["--model", args.model])
        command.extend(["--preferred-provider", args.preferred_provider])
        for provider in args.available_provider:
            command.extend(["--available-provider", provider])
        for path in args.motion_reference_image:
            command.extend(
                ["--motion-reference-image", str(path.expanduser().resolve())]
            )
        for path in args.motion_reference_video:
            command.extend(
                ["--motion-reference-video", str(path.expanduser().resolve())]
            )
        if args.motion_lora is not None:
            command.extend(
                ["--motion-lora", str(args.motion_lora.expanduser().resolve())]
            )
        for enabled, flag in (
            (args.confirm_paid, "--confirm-paid"),
            (args.operator_selected, "--operator-selected"),
            (args.rights_confirmed, "--rights-confirmed"),
            (args.allow_upscale, "--allow-upscale"),
            (args.wait, "--wait"),
            (args.download, "--download"),
            (args.enable_prompt_expansion, "--enable-prompt-expansion"),
            (args.generate_audio, "--generate-audio"),
        ):
            if enabled:
                command.append(flag)
        return _run(command)
    if args.command == "local-models":
        local_model_args = args.args[1:] if args.args[:1] == ["--"] else args.args
        return _run(_reel_command(*local_model_args))
    if args.command == "local-queue":
        local_queue_args = args.args[1:] if args.args[:1] == ["--"] else args.args
        return _run(_local_queue_command(*local_queue_args))
    if args.command == "local-benchmarks":
        benchmark_args = args.args[1:] if args.args[:1] == ["--"] else args.args
        return _run(_local_benchmark_command(*benchmark_args))
    if args.command == "motion-qc-register":
        command = _campaign_command(
            "register-motion-qc-receipt",
            "--rendered-asset-id",
            args.rendered_asset_id,
            "--receipt",
            str(args.receipt.expanduser().resolve()),
        )
        if args.operator:
            command.extend(["--operator", args.operator])
        return _run(command)
    if args.command == "readiness":
        command = _campaign_command("campaign-readiness", "--campaign", args.campaign)
        if args.user_id:
            command.extend(["--user-id", args.user_id])
        return _run(command)
    if args.command == "draft-export":
        if args.max_drafts <= 0:
            print("--max-drafts must be greater than zero", file=sys.stderr)
            return 2
        command = _campaign_command(
            "export-threadsdash",
            "--campaign",
            args.campaign,
            "--user-id",
            args.user_id,
            "--max-drafts",
            str(args.max_drafts),
            "--schedule-mode",
            "draft",
        )
        if args.dry_run:
            command.append("--dry-run")
        if args.review_only:
            command.append("--review-only")
        command.extend(["--surface", args.surface])
        for asset_id in args.rendered_asset_id:
            command.extend(["--rendered-asset-id", asset_id])
        return _run(command)
    raise AssertionError(f"unhandled command: {args.command}")


if __name__ == "__main__":
    raise SystemExit(main())
