#!/usr/bin/env python3
"""Single operator-facing command for the headless Creator OS monorepo."""

from __future__ import annotations

import argparse
import json
import math
import subprocess
import sys
from datetime import UTC, datetime
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]


def _run(command: list[str], *, cwd: Path = ROOT, input_text: str | None = None) -> int:
    return subprocess.run(
        command, cwd=cwd, check=False, input=input_text, text=input_text is not None
    ).returncode


def _campaign_command(*args: str) -> list[str]:
    return ["uv", "run", "--package", "campaign-factory", "campaign-factory", *args]


def _reference_command(*args: str) -> list[str]:
    return [
        "uv",
        "run",
        "--package",
        "reference-factory",
        "python",
        "-m",
        "reference_factory.cli",
        *args,
    ]


def _reel_command(*args: str) -> list[str]:
    return [
        "uv",
        "run",
        "--package",
        "reel-factory",
        "python",
        "-m",
        "reel_factory.local_model_manager",
        *args,
    ]


def _prompt_expander_command(*args: str) -> list[str]:
    return [
        "uv",
        "run",
        "--package",
        "reel-factory",
        "python",
        "-m",
        "reel_factory.local_wan_prompt_expansion",
        *args,
    ]


def _local_queue_command(*args: str) -> list[str]:
    return [
        "uv",
        "run",
        "--package",
        "reel-factory",
        "python",
        "-m",
        "reel_factory.local_generation_queue",
        *args,
    ]


def _local_benchmark_command(*args: str) -> list[str]:
    return [
        "uv",
        "run",
        "--all-packages",
        "python",
        "-m",
        "reel_factory.local_model_benchmark",
        *args,
    ]


def _local_arena_command(*args: str) -> list[str]:
    return [
        "uv",
        "run",
        "--isolated",
        "--offline",
        "--locked",
        "--all-packages",
        "--extra",
        "identity",
        "python",
        "-m",
        "reel_factory.local_model_arena",
        *args,
    ]


def _identity_command(*args: str) -> list[str]:
    return [
        "uv",
        "run",
        "--isolated",
        "--offline",
        "--locked",
        "--all-packages",
        "--extra",
        "identity",
        "python",
        "-m",
        "reel_factory.identity_verification",
        *args,
    ]


def _local_router_command(*args: str) -> list[str]:
    return [
        "uv",
        "run",
        "--all-packages",
        "python",
        "-m",
        "reel_factory.local_model_router",
        *args,
    ]


def _creative_approval_command(*args: str) -> list[str]:
    return [
        "uv",
        "run",
        "--package",
        "campaign-factory",
        "python",
        "-m",
        "campaign_factory.creative_approval",
        *args,
    ]


def _runtime_promotion_command(*args: str) -> list[str]:
    return [
        "uv",
        "run",
        "--package",
        "campaign-factory",
        "python",
        "-m",
        "campaign_factory.runtime_promotion_entrypoint",
        *args,
    ]


def _evidence_key_command(*args: str) -> list[str]:
    return [
        "uv",
        "run",
        "--package",
        "creator-os-core",
        "python",
        "-m",
        "creator_os_core.evidence_attestation",
        *args,
    ]


def _parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="creator-os",
        description="Operate Creator OS through one explicit, headless command surface.",
    )
    sub = parser.add_subparsers(dest="command", required=True)

    status = sub.add_parser(
        "status", help="read-only live configuration/runtime status"
    )
    status.add_argument("--json", action="store_true")
    status.add_argument(
        "--live-read-only",
        action="store_true",
        help="run configured zero-write network/provider probes",
    )

    doctor = sub.add_parser("doctor", help="read-only fixture-backed integrity audit")
    doctor.add_argument("args", nargs=argparse.REMAINDER)

    sync = sub.add_parser(
        "performance-sync",
        help="preview or apply the pinned ThreadsDashboard metrics/learning sync",
    )
    sync_mode = sync.add_mutually_exclusive_group(required=True)
    sync_mode.add_argument("--dry-run", action="store_true")
    sync_mode.add_argument("--apply", action="store_true")

    reference_refresh = sub.add_parser(
        "reference-refresh",
        help="preview or apply the local reference/audio refresh workflow",
    )
    reference_mode = reference_refresh.add_mutually_exclusive_group(required=True)
    reference_mode.add_argument("--dry-run", action="store_true")
    reference_mode.add_argument("--apply", action="store_true")
    reference_refresh.add_argument(
        "--source", type=Path, default=Path.home() / "Downloads/tiktok"
    )
    reference_refresh.add_argument(
        "--audio-export",
        type=Path,
        default=ROOT.parent / "reference_reels/audio_catalog.json",
    )

    generate = sub.add_parser(
        "create",
        aliases=["generate"],
        help="choose one explicit generation mode; use --list-modes for cost and gates",
    )
    generation_choice = generate.add_mutually_exclusive_group(required=True)
    generation_choice.add_argument("--mode")
    generation_choice.add_argument("--list-modes", action="store_true")
    generation_execution = generate.add_mutually_exclusive_group()
    generation_execution.add_argument("--dry-run", action="store_true")
    generation_execution.add_argument("--apply", action="store_true")
    generate.add_argument("--campaign")
    generate.add_argument("--reference-image", type=Path)
    generate.add_argument("--accepted-still", type=Path)
    generate.add_argument("--kling-selection-receipt", type=Path)
    generate.add_argument("--reference-video", type=Path)
    generate.add_argument("--target", help="creator identity/name")
    generate.add_argument("--soul-id")
    generate.add_argument("--workspace", type=Path)
    generate.add_argument("--confirm-paid", action="store_true")
    generate.add_argument("--max-credits", type=float)
    generate.add_argument("--max-usd", type=float)
    generate.add_argument("--caption")
    generate.add_argument("--duration", type=float)
    generate.add_argument("--motion-model")
    generate.add_argument("--local-evidence-bundle", type=Path)
    generate.add_argument("--local-arena-summary", type=Path)
    generate.add_argument("--router-override-operator")
    generate.add_argument("--router-override-reason")
    generate.add_argument(
        "--motion-task",
        choices=[
            "text_to_video",
            "image_to_video",
            "audio_image_to_video",
            "keyframe_interpolation",
            "video_retake",
            "video_extend",
        ],
        default="image_to_video",
    )
    generate.add_argument("--motion-prompt")
    generate.add_argument("--audio", type=Path)
    generate.add_argument("--generate-audio", action="store_true")
    generate.add_argument("--last-image", type=Path)
    generate.add_argument("--source-video", type=Path)
    generate.add_argument("--retake-start-frame", type=int)
    generate.add_argument("--retake-end-frame", type=int)
    generate.add_argument("--extend-frames", type=int)
    generate.add_argument(
        "--extend-direction", choices=["before", "after"], default="after"
    )
    generate.add_argument("--preserve-audio", action="store_true")
    generate.add_argument(
        "--motion-reference-image", type=Path, action="append", default=[]
    )
    generate.add_argument(
        "--motion-reference-video", type=Path, action="append", default=[]
    )
    generate.add_argument("--resolution")
    generate.add_argument("--seed", type=int, default=42)
    generate.add_argument("--steps", type=int)
    generate.add_argument("--enable-prompt-expansion", action="store_true")
    generate.add_argument("--shot-type", choices=["single", "multi"], default="single")
    generate.add_argument(
        "--local-model-dir", "--local-wan-model-dir", dest="local_model_dir", type=Path
    )
    generate.add_argument("--motion-lora", type=Path)
    generate.add_argument("--motion-lora-strength", type=float, default=1.0)
    generate.add_argument("--count", type=int, default=3)
    generate.add_argument("--account")
    generate.add_argument("--folder", type=Path)
    generate.add_argument("--model")
    generate.add_argument(
        "--format", choices=["reel", "slideshow", "auto"], default="auto"
    )
    generate.add_argument("--variant-count", type=int, default=20)
    generate.add_argument("--workers", type=int, default=3)
    generate.add_argument("--first-frame-approval-id")
    generate.add_argument("--last-frame-approval-id")
    generate.add_argument("--operator-selected", action="store_true")
    generate.add_argument("--rights-confirmed", action="store_true")
    generate.add_argument(
        "--preferred-provider", choices=["auto", "seedance", "kling"], default="auto"
    )
    generate.add_argument(
        "--available-provider",
        choices=["seedance", "kling"],
        action="append",
        default=[],
    )
    generate.add_argument("--allow-upscale", action="store_true")
    generate.add_argument("--wait", action="store_true")
    generate.add_argument("--download", action="store_true")

    review = sub.add_parser(
        "review",
        aliases=["readiness"],
        help="ordinary read-only Campaign creative/QC review",
    )
    review.add_argument("--campaign", required=True)
    review.add_argument("--user-id")

    approve = sub.add_parser(
        "approve",
        help="build and sign one immutable v2 approval from an exact review draft",
    )
    approve.add_argument("--campaign", required=True)
    approve.add_argument("--rendered-asset-id", required=True)
    approve.add_argument("--user-id", required=True)
    approve.add_argument("--approved-by", required=True)
    approve.add_argument("--root", type=Path)
    approve.add_argument(
        "--surface",
        choices=[
            "regular_reel",
            "trial_reel",
            "story",
            "story_cta",
            "feed_single",
            "feed_carousel",
        ],
        default="regular_reel",
    )
    approve.add_argument("--publish-mode", choices=["auto", "notify"])

    draft = sub.add_parser(
        "export",
        aliases=["draft-export"],
        help="preview or explicitly write validated drafts; never schedules or publishes",
    )
    draft_mode = draft.add_mutually_exclusive_group(required=True)
    draft_mode.add_argument("--dry-run", action="store_true")
    draft_mode.add_argument("--apply", action="store_true")
    draft.add_argument("--campaign", required=True)
    draft.add_argument("--user-id", required=True)
    draft.add_argument("--max-drafts", type=int, required=True)
    draft.add_argument("--rendered-asset-id", action="append", default=[])
    draft.add_argument(
        "--surface",
        choices=[
            "regular_reel",
            "trial_reel",
            "story",
            "story_cta",
            "feed_single",
            "feed_carousel",
        ],
        default="regular_reel",
        help="Export one explicit distribution surface (default: regular_reel)",
    )
    draft.add_argument("--review-only", action="store_true")

    advanced = sub.add_parser(
        "advanced",
        help="developer diagnostics for local models, queue, benchmarks, and analyzers",
    )
    advanced.add_argument(
        "surface",
        choices=[
            "models",
            "queue",
            "benchmarks",
            "arena",
            "identity",
            "router",
            "analyzers",
            "evidence-key",
            "approval-import",
            "motion-qc-register",
            "prompt-expander",
        ],
    )
    advanced.add_argument("args", nargs=argparse.REMAINDER)

    promote = sub.add_parser(
        "promote",
        help="guardedly promote one reviewed commit into creator-os-runtime",
    )
    promote.add_argument("--source-root", type=Path, default=ROOT)
    promote.add_argument(
        "--runtime-root",
        type=Path,
        required=True,
        help="exact clean runtime checkout; never inferred from a worktree",
    )
    promote.add_argument("--approved-commit", required=True)
    promote.add_argument("--approval", type=Path, required=True)
    promote.add_argument(
        "--state-root",
        type=Path,
        default=Path.home() / ".creator-os/state/runtime_promotions",
    )
    promote.add_argument("--operator", required=True)
    promote.add_argument("--dry-run", action="store_true")

    return parser


def main(argv: list[str] | None = None) -> int:
    effective_argv = list(sys.argv[1:] if argv is None else argv)
    compatibility_surfaces = {
        "local-models": "models",
        "local-queue": "queue",
        "local-benchmarks": "benchmarks",
        "approve-import": "approval-import",
        "motion-qc-register": "motion-qc-register",
    }
    if effective_argv and effective_argv[0] in compatibility_surfaces:
        legacy = effective_argv[0]
        surface = compatibility_surfaces[legacy]
        print(
            f"deprecated: use `creator-os advanced {surface}`; compatibility retained",
            file=sys.stderr,
        )
        effective_argv = ["advanced", surface, *effective_argv[1:]]
    args = _parser().parse_args(effective_argv)
    if args.command == "status":
        command = [sys.executable, str(ROOT / "scripts/doctor.py"), "--status"]
        if args.json:
            command.append("--json")
        if args.live_read_only:
            command.append("--live-read-only")
        return _run(command)
    if args.command == "doctor":
        doctor_args = args.args[1:] if args.args[:1] == ["--"] else args.args
        return _run([sys.executable, str(ROOT / "scripts/doctor.py"), *doctor_args])
    if args.command == "performance-sync":
        command = [str(ROOT / "scripts/run_threadsdash_performance_sync.sh")]
        if args.dry_run:
            command.append("--dry-run")
        return _run(command)
    if args.command == "reference-refresh":
        source = args.source.expanduser().resolve()
        audio_export = args.audio_export.expanduser().resolve()
        commands = [
            _reference_command("import-tiktok-archive", "--source", str(source)),
            _reference_command("refresh-tiktok-audio", "--source", str(source)),
            _reference_command("analyze-audio-patterns"),
            _reference_command("audio-health"),
            _reference_command("list-audio", "--export", str(audio_export)),
            _campaign_command("import-audio-catalog", "--path", str(audio_export)),
        ]
        if args.dry_run:
            for command in commands:
                print(" ".join(command))
            return 0
        for command in commands:
            if code := _run(command):
                return code
        return 0
    if args.command in {"generate", "create"}:
        if args.command == "generate":
            print(
                "deprecated: use `creator-os create`; `generate` remains a compatibility alias",
                file=sys.stderr,
            )
        if args.list_modes:
            return _run(_campaign_command("generation", "modes"))
        if not args.campaign:
            print("create requires --campaign", file=sys.stderr)
            return 2
        if args.dry_run == args.apply:
            print(
                "create requires exactly one of --dry-run or --apply", file=sys.stderr
            )
            return 2
        if args.max_credits is not None and (
            not math.isfinite(args.max_credits) or args.max_credits <= 0
        ):
            print("--max-credits must be finite and greater than zero", file=sys.stderr)
            return 2
        if args.max_usd is not None and (
            not math.isfinite(args.max_usd) or args.max_usd <= 0
        ):
            print("--max-usd must be finite and greater than zero", file=sys.stderr)
            return 2
        if args.duration is not None and (
            not math.isfinite(args.duration) or args.duration <= 0
        ):
            print("--duration must be finite and greater than zero", file=sys.stderr)
            return 2
        if args.count <= 0 or args.variant_count <= 0 or args.workers <= 0:
            print(
                "--count, --variant-count, and --workers must be greater than zero",
                file=sys.stderr,
            )
            return 2
        command = _campaign_command(
            "generation",
            "run",
            "--mode",
            args.mode,
            "--campaign",
            args.campaign,
            "--apply" if args.apply else "--dry-run",
        )
        optional_paths = (
            ("--reference-image", args.reference_image),
            ("--accepted-still", args.accepted_still),
            ("--kling-selection-receipt", args.kling_selection_receipt),
            ("--reference-video", args.reference_video),
            ("--workspace", args.workspace),
            ("--folder", args.folder),
            ("--audio", args.audio),
            ("--last-image", args.last_image),
            ("--source-video", args.source_video),
            ("--local-model-dir", args.local_model_dir),
            ("--local-evidence-bundle", args.local_evidence_bundle),
            ("--local-arena-summary", args.local_arena_summary),
        )
        for flag, value in optional_paths:
            if value is not None:
                command.extend([flag, str(value.expanduser().resolve())])
        optional_values = (
            ("--target", args.target),
            ("--soul-id", args.soul_id),
            ("--max-credits", args.max_credits),
            ("--max-usd", args.max_usd),
            ("--caption", args.caption),
            ("--duration", args.duration),
            ("--account", args.account),
            ("--first-frame-approval-id", args.first_frame_approval_id),
            ("--last-frame-approval-id", args.last_frame_approval_id),
            ("--motion-model", args.motion_model),
            ("--router-override-operator", args.router_override_operator),
            ("--router-override-reason", args.router_override_reason),
            ("--motion-task", args.motion_task),
            ("--motion-prompt", args.motion_prompt),
            ("--resolution", args.resolution),
            ("--seed", args.seed),
            ("--steps", args.steps),
            ("--shot-type", args.shot_type),
            ("--motion-lora-strength", args.motion_lora_strength),
            ("--retake-start-frame", args.retake_start_frame),
            ("--retake-end-frame", args.retake_end_frame),
            ("--extend-frames", args.extend_frames),
            ("--extend-direction", args.extend_direction),
        )
        for flag, value in optional_values:
            if value is not None:
                command.extend([flag, str(value)])
        command.extend(["--count", str(args.count)])
        command.extend(["--variant-count", str(args.variant_count)])
        command.extend(["--workers", str(args.workers)])
        command.extend(["--format", args.format])
        if args.model:
            command.extend(["--model", args.model])
        if args.preserve_audio:
            command.append("--preserve-audio")
        command.extend(["--preferred-provider", args.preferred_provider])
        for provider in args.available_provider:
            command.extend(["--available-provider", provider])
        for path in args.motion_reference_image:
            command.extend(
                ["--motion-reference-image", str(path.expanduser().resolve())]
            )
        for path in args.motion_reference_video:
            command.extend(
                ["--motion-reference-video", str(path.expanduser().resolve())]
            )
        if args.motion_lora is not None:
            command.extend(
                ["--motion-lora", str(args.motion_lora.expanduser().resolve())]
            )
        for enabled, flag in (
            (args.confirm_paid, "--confirm-paid"),
            (args.operator_selected, "--operator-selected"),
            (args.rights_confirmed, "--rights-confirmed"),
            (args.allow_upscale, "--allow-upscale"),
            (args.wait, "--wait"),
            (args.download, "--download"),
            (args.enable_prompt_expansion, "--enable-prompt-expansion"),
            (args.generate_audio, "--generate-audio"),
        ):
            if enabled:
                command.append(flag)
        return _run(command)
    if args.command in {"readiness", "review"}:
        if args.command == "readiness":
            print(
                "deprecated: use `creator-os review`; compatibility retained",
                file=sys.stderr,
            )
        command = _campaign_command("campaign-readiness", "--campaign", args.campaign)
        if args.user_id:
            command.extend(["--user-id", args.user_id])
        return _run(command)
    if args.command == "approve":
        command = _campaign_command(
            "creative-approval-build",
            "--campaign",
            args.campaign,
            "--rendered-asset-id",
            args.rendered_asset_id,
            "--user-id",
            args.user_id,
            "--approved-by",
            args.approved_by,
            "--surface",
            args.surface,
        )
        if args.publish_mode:
            command.extend(["--publish-mode", args.publish_mode])
        if args.root is not None:
            command.extend(["--root", str(args.root.expanduser().resolve())])
        return _run(command)
    if args.command in {"draft-export", "export"}:
        if args.command == "draft-export":
            print(
                "deprecated: use `creator-os export`; compatibility retained",
                file=sys.stderr,
            )
        if args.max_drafts <= 0:
            print("--max-drafts must be greater than zero", file=sys.stderr)
            return 2
        command = _campaign_command(
            "export-threadsdash",
            "--campaign",
            args.campaign,
            "--user-id",
            args.user_id,
            "--max-drafts",
            str(args.max_drafts),
            "--schedule-mode",
            "draft",
        )
        if args.dry_run:
            command.append("--dry-run")
        if args.review_only:
            command.append("--review-only")
        command.extend(["--surface", args.surface])
        for asset_id in args.rendered_asset_id:
            command.extend(["--rendered-asset-id", asset_id])
        return _run(command)
    if args.command == "advanced":
        advanced_args = args.args[1:] if args.args[:1] == ["--"] else args.args
        if args.surface == "models":
            return _run(_reel_command(*advanced_args))
        if args.surface == "prompt-expander":
            return _run(_prompt_expander_command(*advanced_args))
        if args.surface == "queue":
            return _run(_local_queue_command(*advanced_args))
        if args.surface == "benchmarks":
            return _run(_local_benchmark_command(*advanced_args))
        if args.surface == "arena":
            return _run(_local_arena_command(*advanced_args))
        if args.surface == "identity":
            return _run(_identity_command(*advanced_args))
        if args.surface == "router":
            return _run(_local_router_command(*advanced_args))
        if args.surface == "evidence-key":
            evidence_key = argparse.ArgumentParser(
                prog="creator-os advanced evidence-key"
            )
            evidence_key_subcommands = evidence_key.add_subparsers(
                dest="evidence_key_command", required=True
            )
            evidence_key_init = evidence_key_subcommands.add_parser("init")
            evidence_key_mode = evidence_key_init.add_mutually_exclusive_group(
                required=True
            )
            evidence_key_mode.add_argument("--dry-run", action="store_true")
            evidence_key_mode.add_argument("--apply", action="store_true")
            evidence_key_args = evidence_key.parse_args(advanced_args)
            return _run(
                _evidence_key_command(
                    "init", "--apply" if evidence_key_args.apply else "--dry-run"
                )
            )
        if args.surface == "approval-import":
            compatibility = argparse.ArgumentParser(
                prog="creator-os advanced approval-import"
            )
            compatibility.add_argument("--approval", type=Path, required=True)
            compatibility.add_argument("--root", type=Path)
            approval_args = compatibility.parse_args(advanced_args)
            command = _creative_approval_command(
                "--approval", str(approval_args.approval.expanduser().resolve())
            )
            if approval_args.root is not None:
                command.extend(
                    ["--root", str(approval_args.root.expanduser().resolve())]
                )
            return _run(command)
        if args.surface == "motion-qc-register":
            compatibility = argparse.ArgumentParser(
                prog="creator-os advanced motion-qc-register"
            )
            compatibility.add_argument("--rendered-asset-id", required=True)
            compatibility.add_argument("--receipt", type=Path, required=True)
            compatibility.add_argument("--operator")
            receipt_args = compatibility.parse_args(advanced_args)
            command = _campaign_command(
                "register-motion-qc-receipt",
                "--rendered-asset-id",
                receipt_args.rendered_asset_id,
                "--receipt",
                str(receipt_args.receipt.expanduser().resolve()),
            )
            if receipt_args.operator:
                command.extend(["--operator", receipt_args.operator])
            return _run(command)
        if args.surface == "analyzers":
            analyzers = argparse.ArgumentParser(
                prog="creator-os advanced analyzers",
                description="Emit the canonical ContentForge analyzer registry.",
            )
            analyzers.parse_args(advanced_args)
            request = json.dumps({"producedAt": datetime.now(UTC).isoformat()})
            return _run(
                [
                    "node",
                    str(ROOT / "packages/contentforge/cli.mjs"),
                    "analyzer-registry",
                ],
                cwd=ROOT,
                input_text=request,
            )
        raise AssertionError(f"unhandled advanced surface: {args.surface}")
    if args.command == "promote":
        command = _runtime_promotion_command(
            "--source-root",
            str(args.source_root.expanduser().resolve()),
            "--runtime-root",
            str(args.runtime_root.expanduser().resolve()),
            "--approved-commit",
            args.approved_commit,
            "--approval",
            str(args.approval.expanduser().resolve()),
            "--state-root",
            str(args.state_root.expanduser().resolve()),
            "--operator",
            args.operator,
        )
        if args.dry_run:
            command.append("--dry-run")
        return _run(command)
    raise AssertionError(f"unhandled command: {args.command}")


if __name__ == "__main__":
    raise SystemExit(main())
