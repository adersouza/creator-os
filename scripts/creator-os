#!/usr/bin/env python3
"""Single operator-facing command for the headless Creator OS monorepo."""

from __future__ import annotations

import argparse
import math
import os
import subprocess
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]

def _run(command: list[str], *, cwd: Path = ROOT) -> int:
    return subprocess.run(command, cwd=cwd, check=False).returncode


def _campaign_command(*args: str) -> list[str]:
    return ["uv", "run", "--package", "campaign-factory", "campaign-factory", *args]


def _reference_command(*args: str) -> list[str]:
    return [
        "uv",
        "run",
        "--package",
        "reference-factory",
        "python",
        "-m",
        "reference_factory.cli",
        *args,
    ]


def _parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="creator-os",
        description="Operate Creator OS through one explicit, headless command surface.",
    )
    sub = parser.add_subparsers(dest="command", required=True)

    status = sub.add_parser("status", help="read-only live configuration/runtime status")
    status.add_argument("--json", action="store_true")

    doctor = sub.add_parser("doctor", help="read-only fixture-backed integrity audit")
    doctor.add_argument("args", nargs=argparse.REMAINDER)

    sync = sub.add_parser(
        "performance-sync",
        help="preview or apply the pinned ThreadsDashboard metrics/learning sync",
    )
    sync_mode = sync.add_mutually_exclusive_group(required=True)
    sync_mode.add_argument("--dry-run", action="store_true")
    sync_mode.add_argument("--apply", action="store_true")

    reference_refresh = sub.add_parser(
        "reference-refresh",
        help="preview or apply the local reference/audio refresh workflow",
    )
    reference_mode = reference_refresh.add_mutually_exclusive_group(required=True)
    reference_mode.add_argument("--dry-run", action="store_true")
    reference_mode.add_argument("--apply", action="store_true")
    reference_refresh.add_argument(
        "--source", type=Path, default=Path.home() / "Downloads/tiktok"
    )
    reference_refresh.add_argument(
        "--audio-export",
        type=Path,
        default=ROOT.parent / "reference_reels/audio_catalog.json",
    )

    prepare = sub.add_parser(
        "campaign-prepare",
        help="build a local review batch; never exports or auto-approves",
    )
    prepare.add_argument("--confirm-write", action="store_true", required=True)
    prepare.add_argument("--folder", type=Path, required=True)
    prepare.add_argument("--campaign", required=True)
    prepare.add_argument("--model", required=True)
    prepare.add_argument(
        "--format", choices=["reel", "slideshow", "auto"], default="auto"
    )
    prepare.add_argument("--variant-count", type=int, default=20)

    static_reel = sub.add_parser(
        "static-reel", help="preview or create one free static MP4 from an accepted still"
    )
    static_mode = static_reel.add_mutually_exclusive_group(required=True)
    static_mode.add_argument("--dry-run", action="store_true")
    static_mode.add_argument("--apply", action="store_true")
    static_reel.add_argument("--campaign", required=True)
    static_reel.add_argument("--still", type=Path, required=True)
    static_reel.add_argument("--duration", type=float)
    static_reel.add_argument("--allow-upscale", action="store_true")

    readiness = sub.add_parser(
        "readiness", help="read-only Campaign Factory QC/readiness decision"
    )
    readiness.add_argument("--campaign", required=True)
    readiness.add_argument("--user-id")

    draft = sub.add_parser(
        "draft-export",
        help="preview or explicitly write validated drafts; never schedules or publishes",
    )
    draft_mode = draft.add_mutually_exclusive_group(required=True)
    draft_mode.add_argument("--dry-run", action="store_true")
    draft_mode.add_argument("--apply", action="store_true")
    draft.add_argument("--campaign", required=True)
    draft.add_argument("--user-id", required=True)
    draft.add_argument("--max-drafts", type=int, required=True)
    draft.add_argument("--rendered-asset-id", action="append", default=[])
    draft.add_argument("--review-only", action="store_true")

    paid = sub.add_parser(
        "paid-generation",
        help="run one explicitly bounded paid front-generation request",
    )
    paid.add_argument("--confirm-paid", action="store_true", required=True)
    paid.add_argument("--target", required=True, help="creator identity/name")
    paid.add_argument("--workspace", type=Path, required=True)
    paid.add_argument("--campaign", required=True)
    paid.add_argument("--reference-image", type=Path, required=True)
    paid.add_argument("--max-credits", type=float, required=True)
    paid.add_argument(
        "--animation-mode",
        choices=["static", "kling", "motion_edit"],
        default="static",
    )
    paid.add_argument("--wait", action="store_true")
    paid.add_argument("--download", action="store_true")
    return parser


def main(argv: list[str] | None = None) -> int:
    args = _parser().parse_args(argv)
    if args.command == "status":
        command = [sys.executable, str(ROOT / "scripts/doctor.py"), "--status"]
        if args.json:
            command.append("--json")
        return _run(command)
    if args.command == "doctor":
        doctor_args = args.args[1:] if args.args[:1] == ["--"] else args.args
        return _run([sys.executable, str(ROOT / "scripts/doctor.py"), *doctor_args])
    if args.command == "performance-sync":
        command = [str(ROOT / "scripts/run_threadsdash_performance_sync.sh")]
        if args.dry_run:
            command.append("--dry-run")
        return _run(command)
    if args.command == "reference-refresh":
        source = args.source.expanduser().resolve()
        audio_export = args.audio_export.expanduser().resolve()
        commands = [
            _reference_command("import-tiktok-archive", "--source", str(source)),
            _reference_command("refresh-tiktok-audio", "--source", str(source)),
            _reference_command("analyze-audio-patterns"),
            _reference_command("audio-health"),
            _reference_command("list-audio", "--export", str(audio_export)),
            _campaign_command("import-audio-catalog", "--path", str(audio_export)),
        ]
        if args.dry_run:
            for command in commands:
                print(" ".join(command))
            return 0
        for command in commands:
            if code := _run(command):
                return code
        return 0
    if args.command == "campaign-prepare":
        if args.variant_count <= 0:
            print("--variant-count must be greater than zero", file=sys.stderr)
            return 2
        return _run(
            _campaign_command(
                "make-batch",
                "--folder",
                str(args.folder.expanduser().resolve()),
                "--campaign",
                args.campaign,
                "--model",
                args.model,
                "--format",
                args.format,
                "--variant-count",
                str(args.variant_count),
                "--dry-run-export",
                "--no-auto-approve",
            )
        )
    if args.command == "static-reel":
        command = _campaign_command(
            "animation",
            "static-mp4",
            "--campaign",
            args.campaign,
            "--still",
            str(args.still.expanduser().resolve()),
            "--apply" if args.apply else "--dry-run",
        )
        if args.duration is not None:
            if not math.isfinite(args.duration) or args.duration <= 0:
                print("--duration must be finite and greater than zero", file=sys.stderr)
                return 2
            command.extend(["--duration", str(args.duration)])
        if args.allow_upscale:
            command.append("--allow-upscale")
        return _run(command)
    if args.command == "readiness":
        command = _campaign_command(
            "campaign-readiness", "--campaign", args.campaign
        )
        if args.user_id:
            command.extend(["--user-id", args.user_id])
        return _run(command)
    if args.command == "draft-export":
        if args.max_drafts <= 0:
            print("--max-drafts must be greater than zero", file=sys.stderr)
            return 2
        command = _campaign_command(
            "export-threadsdash",
            "--campaign",
            args.campaign,
            "--user-id",
            args.user_id,
            "--max-drafts",
            str(args.max_drafts),
            "--schedule-mode",
            "draft",
        )
        if args.dry_run:
            command.append("--dry-run")
        if args.review_only:
            command.append("--review-only")
        for asset_id in args.rendered_asset_id:
            command.extend(["--rendered-asset-id", asset_id])
        return _run(command)
    if args.command == "paid-generation":
        workspace = args.workspace.expanduser().resolve()
        if workspace != ROOT:
            print(
                f"--workspace must be this checkout ({ROOT}); got {workspace}",
                file=sys.stderr,
            )
            return 2
        if not math.isfinite(args.max_credits) or args.max_credits <= 0:
            print(
                "--max-credits must be finite and greater than zero",
                file=sys.stderr,
            )
            return 2
        reference = args.reference_image.expanduser().resolve()
        command = _campaign_command(
            "generation",
            "front-link",
            "--campaign",
            args.campaign,
            "--reference-image",
            str(reference),
            "--creator",
            args.target,
            "--animation-mode",
            args.animation_mode,
            "--budget-cap-credits",
            str(args.max_credits),
            "--enable-paid-generation",
            "--apply",
        )
        if args.wait:
            command.append("--wait")
        if args.download:
            command.append("--download")
        env = dict(os.environ)
        env["CREATOR_OS_ROOT"] = str(workspace)
        return subprocess.run(command, cwd=workspace, env=env, check=False).returncode
    raise AssertionError(f"unhandled command: {args.command}")


if __name__ == "__main__":
    raise SystemExit(main())
