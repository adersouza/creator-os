#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
usage() {
  cat >&2 <<'EOF'
Usage: scripts/run/reel-factory <command> [args...]

Commands:
  generate-assets  Run generate_assets.py
  reel-pipeline    Run reel_pipeline.py
  caption-bank     Run caption_bank.py
  next-batch       Run next_batch.py
  review-guard     Validate a review batch manifest
EOF
}

if [ "$#" -lt 1 ]; then
  usage
  exit 2
fi

command="$1"
shift

cd "$REPO_ROOT"
case "$command" in
  generate-assets)
    exec uv run --package reel-factory python -m reel_factory.generate_assets "$@"
    ;;
  reel-pipeline)
    exec uv run --package reel-factory python -m reel_factory.reel_pipeline "$@"
    ;;
  caption-bank)
    exec uv run --package reel-factory python -m reel_factory.caption_bank "$@"
    ;;
  next-batch)
    exec uv run --package reel-factory python -m reel_factory.next_batch "$@"
    ;;
  review-guard)
    exec uv run --package reel-factory python -m reel_factory.review_batch_guard "$@"
    ;;
  -h|--help|help)
    usage
    ;;
  *)
    echo "Unknown reel-factory command: $command" >&2
    usage
    exit 2
    ;;
esac
