#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
REEL_ROOT="$REPO_ROOT/python_packages/reel_factory"

usage() {
  cat >&2 <<'EOF'
Usage: scripts/run/reel-factory <command> [args...]

Commands:
  generate-assets  Run generate_assets.py
  reel-pipeline    Run reel_pipeline.py
  caption-bank     Run caption_bank.py
  next-batch       Run next_batch.py
EOF
}

if [ "$#" -lt 1 ]; then
  usage
  exit 2
fi

command="$1"
shift

cd "$REPO_ROOT"
case "$command" in
  generate-assets)
    exec uv run --package reel-factory python "$REEL_ROOT/generate_assets.py" "$@"
    ;;
  reel-pipeline)
    exec uv run --package reel-factory python "$REEL_ROOT/reel_pipeline.py" "$@"
    ;;
  caption-bank)
    exec uv run --package reel-factory python "$REEL_ROOT/caption_bank.py" "$@"
    ;;
  next-batch)
    exec uv run --package reel-factory python "$REEL_ROOT/next_batch.py" "$@"
    ;;
  -h|--help|help)
    usage
    ;;
  *)
    echo "Unknown reel-factory command: $command" >&2
    usage
    exit 2
    ;;
esac
