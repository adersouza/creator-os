{
  "name": "creator-os",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "node": "22.x || 24.x || >=26"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "doctor": "python3 scripts/doctor.py",
    "sync:contracts": "node scripts/generate-pipeline-contract-schemas.mjs",
    "lint:py": "uv run ruff check python_packages packages && uv run ruff format --check python_packages packages",
    "typecheck:py": "uv run mypy packages/pipeline_contracts/pipeline_contracts",
    "check:all": "pnpm check:contracts && pnpm lint:py && pnpm typecheck:py && pnpm --filter contentforge lint && pnpm check:arch && pnpm check:artifacts",
    "check:contracts": "node scripts/generate-pipeline-contract-schemas.mjs --check",
    "check:integration": "uv run pytest tests/integration",
    "check:artifacts": "bash scripts/check-runtime-artifacts.sh",
    "check:arch": "pnpm check:arch:ts && pnpm check:arch:py",
    "check:arch:fixtures": "bash scripts/test-architecture-guards.sh",
    "check:arch:py": "uv run lint-imports && python3 scripts/check-python-architecture-boundaries.py",
    "check:arch:ts": "depcruise apps packages --config .dependency-cruiser.cjs --output-type err",
    "graphify:update": "bash scripts/graphify-update.sh",
    "lint": "turbo run lint",
    "audit:js-dead": "knip --workspace apps/contentforge --no-exit-code",
    "security:codeql-note": "node scripts/security/codeql-note.mjs",
    "security:secrets": "bash scripts/security/secret-scan.sh"
  },
  "devDependencies": {
    "dependency-cruiser": "^18.0.0",
    "knip": "^6.25.0",
    "turbo": "^2.10.4"
  }
}
