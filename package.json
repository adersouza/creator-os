{
  "name": "creator-os",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "node": "22.x || 24.x || >=26"
  },
  "scripts": {
    "creator-os": "python3 scripts/creator-os",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "doctor": "python3 scripts/creator-os doctor",
    "sync:contracts": "node scripts/generate-pipeline-contract-schemas.mjs",
    "pack:contracts": "pnpm --dir packages/pipeline_contracts pack --pack-destination ../../artifacts/pipeline-contracts",
    "lint:py": "uv run ruff check python_packages packages && uv run ruff format --check python_packages packages",
    "typecheck:py": "uv run mypy packages/pipeline_contracts/pipeline_contracts && uv run python scripts/check_mypy_backlog.py",
    "check:all": "pnpm check:contracts && pnpm check:prompts && pnpm lint:py && pnpm typecheck:py && pnpm --filter contentforge lint && pnpm check:arch && pnpm check:artifacts",
    "check:contracts": "node scripts/generate-pipeline-contract-schemas.mjs --check",
    "check:integration": "uv run python -m pytest tests/integration",
    "check:prompts": "bash scripts/check-prompt-regressions.sh",
    "check:artifacts": "bash scripts/check-runtime-artifacts.sh",
    "check:arch": "pnpm check:arch:ts && pnpm check:arch:py",
    "check:arch:fixtures": "bash scripts/test-architecture-guards.sh",
    "check:arch:py": "uv run lint-imports && python3 scripts/check-python-architecture-boundaries.py",
    "check:arch:ts": "depcruise packages --config .dependency-cruiser.cjs --output-type err",
    "graphify:update": "bash scripts/graphify-update.sh",
    "lint": "turbo run lint",
    "audit:js-dead": "knip --workspace packages/contentforge --no-exit-code",
    "security:codeql-note": "node scripts/security/codeql-note.mjs",
    "security:secrets": "bash scripts/security/secret-scan.sh"
  },
  "devDependencies": {
    "dependency-cruiser": "^18.1.0",
    "knip": "^6.29.0",
    "promptfoo": "0.121.19",
    "turbo": "^2.10.6"
  }
}
