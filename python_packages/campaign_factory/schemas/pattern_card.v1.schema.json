{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "reference_factory.pattern_card.v1",
  "title": "Reference Factory Viral Pattern Card",
  "type": "object",
  "required": [
    "schema",
    "id",
    "platform",
    "source",
    "formatType",
    "hookType",
    "visualPattern",
    "shotSequence",
    "cameraStyle",
    "subjectAction",
    "textOverlayStyle",
    "pacing",
    "audioVibe",
    "reuseRisk",
    "copyRiskNotes",
    "transformationInstructions"
  ],
  "properties": {
    "schema": { "const": "reference_factory.pattern_card.v1" },
    "id": { "type": "string" },
    "platform": { "type": "string" },
    "source": { "type": "object" },
    "formatType": { "type": "string" },
    "hookType": { "type": "string" },
    "visualPattern": { "type": "string" },
    "shotSequence": { "type": "array" },
    "cameraStyle": { "type": "object" },
    "subjectAction": { "type": "string" },
    "textOverlayStyle": { "type": "object" },
    "pacing": { "type": "object" },
    "audioVibe": { "type": "object" },
    "ctaPattern": { "type": ["string", "null"] },
    "reuseRisk": { "type": "string", "enum": ["low", "medium", "high"] },
    "copyRiskNotes": { "type": "array" },
    "transformationInstructions": { "type": "array" },
    "viralityMetrics": { "type": "object" },
    "qualityWarnings": { "type": "array" }
  }
}
