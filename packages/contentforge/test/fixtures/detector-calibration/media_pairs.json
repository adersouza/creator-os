      "expected": { "rawVerdict": "match", "campaignVerdict": "fail", "campaignUploadReady": false }
    },
    {
      "id": "pdq_hamming_40_gate_gap",
      "detector": "pdq",
      "source": "known_collision_source.png",
      "target": "known_safe_target_boundary_pdq_hamming_40.png",
