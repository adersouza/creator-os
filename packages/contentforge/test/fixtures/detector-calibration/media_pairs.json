{
  "schema": "contentforge.detector_calibration_pairs.v1",
  "notes": [
    "Recorded edge measurements for known source/variant media pairs.",
    "The fixture pins detector threshold semantics without requiring heavyweight local SSCD model files in CI."
  ],
  "pairs": [
