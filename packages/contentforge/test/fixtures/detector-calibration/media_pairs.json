      "expected": { "rawVerdict": "distinct", "campaignVerdict": "fail", "campaignUploadReady": false }
    },
    {
      "id": "pdq_hamming_41_distinct",
      "detector": "pdq",
      "source": "known_collision_source.png",
      "target": "known_distinct_pdq_hamming_41.png",
      "measurement": { "hammingDistance": 41 },
      "expected": { "rawVerdict": "distinct", "campaignVerdict": "pass", "campaignUploadReady": true }
    },
    {
      "id": "sscd_cosine_0_75_copy",
      "detector": "sscd",
