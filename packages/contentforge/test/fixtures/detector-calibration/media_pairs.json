      "expected": { "rawVerdict": "similar", "campaignVerdict": "fail", "campaignUploadReady": false }
    },
    {
      "id": "sscd_cosine_0_49_distinct",
      "detector": "sscd",
      "source": "known_copy_source.png",
      "target": "known_distinct_sscd_cosine_0_49.png",
