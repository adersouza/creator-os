{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "reel_factory.local_model_arena_unblinding_receipt.v1",
  "title": "Local Model Arena Unblinding Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "receiptId", "arenaPlanId", "arenaPlanFingerprint", "reviewPacketId", "reviewPacketFingerprint", "createdAt", "expectedReviewCount", "lockedReviewSetFingerprint", "bindings", "providerCalls", "productionWrites", "producerAttestation", "receiptFingerprint"],
  "properties": {
    "schema": {"const": "reel_factory.local_model_arena_unblinding_receipt.v1"},
    "receiptId": {"type": "string", "minLength": 1},
    "arenaPlanId": {"type": "string", "minLength": 1},
    "arenaPlanFingerprint": {"$ref": "#/$defs/sha256"},
    "reviewPacketId": {"type": "string", "minLength": 1},
    "reviewPacketFingerprint": {"$ref": "#/$defs/sha256"},
    "createdAt": {"type": "string", "format": "date-time"},
    "expectedReviewCount": {"type": "integer", "minimum": 1},
    "lockedReviewSetFingerprint": {"$ref": "#/$defs/sha256"},
    "bindings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["blindedCandidateId", "subjectSha256", "humanReviewId", "humanReviewFingerprint", "sampleId", "modelId", "modelRevision", "modelManifestSha256", "modelDeepVerificationFingerprint", "modelFingerprint"],
        "properties": {
          "blindedCandidateId": {"type": "string", "minLength": 1},
          "subjectSha256": {"$ref": "#/$defs/sha256"},
          "humanReviewId": {"type": "string", "minLength": 1},
          "humanReviewFingerprint": {"$ref": "#/$defs/sha256"},
          "sampleId": {"type": "string", "minLength": 1},
          "modelId": {"type": "string", "minLength": 1},
          "modelRevision": {"type": "string", "minLength": 1},
          "modelManifestSha256": {"$ref": "#/$defs/sha256"},
          "modelDeepVerificationFingerprint": {"$ref": "#/$defs/sha256"},
          "modelFingerprint": {"$ref": "#/$defs/sha256"}
        }
      }
    },
    "providerCalls": {"const": 0},
    "productionWrites": {"const": 0},
    "producerAttestation": {"$ref": "evidence_attestation.v1.schema.json"},
    "receiptFingerprint": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
  }
}
