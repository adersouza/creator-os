{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "reel_factory.local_model_arena_plan.v1",
  "title": "Local Model Arena Plan",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "planId", "purpose", "createdAt", "creators", "expectedSampleCount", "samples", "providerCalls", "productionWritesAllowed", "planFingerprint"],
  "properties": {
    "schema": {"const": "reel_factory.local_model_arena_plan.v1"},
    "planId": {"type": "string", "minLength": 1},
    "purpose": {"enum": ["exploratory", "promotion_eligible"]},
    "createdAt": {"type": "string", "format": "date-time"},
    "creators": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["stacey", "larissa", "lola"]}},
    "expectedSampleCount": {"type": "integer", "minimum": 1},
    "samples": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/sample"}},
    "providerCalls": {"const": 0},
    "productionWritesAllowed": {"const": false},
    "planFingerprint": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "fingerprint"],
      "properties": {"id": {"type": "string", "minLength": 1}, "fingerprint": {"$ref": "#/$defs/sha256"}}
    },
    "runtimeBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runtimeId", "repository", "revision", "platform", "platformRelease", "osBuild", "machine", "python", "pythonExecutable", "pythonExecutableResolved", "mlxVersion", "runtimeReceiptFingerprint", "resolvedEnvironmentFingerprint", "ffmpegExecutable", "ffmpegSha256", "ffmpegSize", "ffmpegVersion", "ffprobeExecutable", "ffprobeSha256", "ffprobeSize", "ffprobeVersion"],
      "properties": {
        "runtimeId": {"type": "string", "minLength": 1},
        "repository": {"type": "string", "minLength": 1},
        "revision": {"type": "string", "minLength": 1},
        "platform": {"type": "string", "minLength": 1},
        "platformRelease": {"type": "string", "minLength": 1},
        "osBuild": {"type": "string", "minLength": 1},
        "machine": {"type": "string", "minLength": 1},
        "python": {"type": "string", "minLength": 1},
        "pythonExecutable": {"type": "string", "minLength": 1},
        "pythonExecutableResolved": {"type": "string", "minLength": 1},
        "mlxVersion": {"type": "string", "minLength": 1},
        "runtimeReceiptFingerprint": {"$ref": "#/$defs/sha256"},
        "resolvedEnvironmentFingerprint": {"$ref": "#/$defs/sha256"},
        "ffmpegExecutable": {"type": "string", "minLength": 1},
        "ffmpegSha256": {"$ref": "#/$defs/sha256"},
        "ffmpegSize": {"type": "integer", "minimum": 1},
        "ffmpegVersion": {"type": "string", "minLength": 1},
        "ffprobeExecutable": {"type": "string", "minLength": 1},
        "ffprobeSha256": {"$ref": "#/$defs/sha256"},
        "ffprobeSize": {"type": "integer", "minimum": 1},
        "ffprobeVersion": {"type": "string", "minLength": 1}
      }
    },
    "licensePolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["licenseId", "commercialUse", "declaredAnnualRevenueUsd", "commercialRevenueLimitUsd", "commercialUseAllowed", "aiDisclosureRequired"],
      "properties": {
        "licenseId": {"type": "string", "minLength": 1},
        "commercialUse": {"type": "boolean"},
        "declaredAnnualRevenueUsd": {"type": ["integer", "null"], "minimum": 0},
        "commercialRevenueLimitUsd": {"type": ["integer", "null"], "minimum": 1},
        "commercialUseAllowed": {"const": true},
        "aiDisclosureRequired": {"type": "boolean"}
      }
    },
    "queueJob": {
      "type": "object",
      "additionalProperties": false,
      "required": ["jobId", "modelId", "modelFingerprint", "taskKind", "taskFingerprint", "inputFingerprint", "requestedMemoryBytes", "paramsFingerprint", "ownedArtifactPaths", "creatorIdentityProfileId", "creatorIdentityProfileFingerprint", "contentIntentId", "contentIntentFingerprint", "benchmarkRecipeId", "benchmarkRecipeFingerprint", "analyzerRegistryId", "analyzerRegistryFingerprint", "runtimeBinding", "runtimeBindingFingerprint", "licensePolicy", "licensePolicyFingerprint"],
      "properties": {
        "jobId": {"type": "string", "minLength": 1},
        "modelId": {"type": "string", "minLength": 1},
        "modelFingerprint": {"$ref": "#/$defs/sha256"},
        "taskKind": {"type": "string", "minLength": 1},
        "taskFingerprint": {"$ref": "#/$defs/sha256"},
        "inputFingerprint": {"$ref": "#/$defs/sha256"},
        "requestedMemoryBytes": {"type": "integer", "minimum": 1},
        "paramsFingerprint": {"$ref": "#/$defs/sha256"},
        "ownedArtifactPaths": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "creatorIdentityProfileId": {"type": "string", "minLength": 1},
        "creatorIdentityProfileFingerprint": {"$ref": "#/$defs/sha256"},
        "contentIntentId": {"type": "string", "minLength": 1},
        "contentIntentFingerprint": {"$ref": "#/$defs/sha256"},
        "benchmarkRecipeId": {"type": "string", "minLength": 1},
        "benchmarkRecipeFingerprint": {"$ref": "#/$defs/sha256"},
        "analyzerRegistryId": {"type": "string", "minLength": 1},
        "analyzerRegistryFingerprint": {"$ref": "#/$defs/sha256"},
        "runtimeBinding": {"$ref": "#/$defs/runtimeBinding"},
        "runtimeBindingFingerprint": {"$ref": "#/$defs/sha256"},
        "licensePolicy": {"$ref": "#/$defs/licensePolicy"},
        "licensePolicyFingerprint": {"$ref": "#/$defs/sha256"}
      }
    },
    "sample": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sampleId", "creatorId", "identityProfileId", "identityProfileFingerprint", "creatorIdentityProfile", "contentIntentId", "contentIntentFingerprint", "contentIntent", "sourcePath", "sourceSha256", "audioPath", "audioSha256", "lastImagePath", "lastImageSha256", "sourceVideoPath", "sourceVideoSha256", "retakeStartFrame", "retakeEndFrame", "extendFrames", "extendDirection", "preserveAudio", "modelId", "modelRevision", "modelManifestSha256", "modelDeepVerificationFingerprint", "runtimeBinding", "runtimeBindingFingerprint", "licensePolicy", "licensePolicyFingerprint", "modelFingerprint", "capabilityCohort", "taskKind", "prompt", "seed", "durationSeconds", "resolution", "audioMode", "commercialUse", "commercialAnnualRevenueUsd", "overlaysExist", "outputPath", "blindedCandidateId", "queueJob", "queueJobFingerprint", "benchmarkRecipe", "benchmarkRecipeFingerprint", "analyzerRegistry", "analyzerRegistryFingerprint", "promotionEligible"],
      "properties": {
        "sampleId": {"type": "string", "minLength": 1},
        "creatorId": {"enum": ["stacey", "larissa", "lola"]},
        "identityProfileId": {"type": "string", "minLength": 1},
        "identityProfileFingerprint": {"$ref": "#/$defs/sha256"},
        "creatorIdentityProfile": {"$ref": "creator_identity_profile.v1.schema.json"},
        "contentIntentId": {"type": "string", "minLength": 1},
        "contentIntentFingerprint": {"$ref": "#/$defs/sha256"},
        "contentIntent": {"$ref": "content_intent.v1.schema.json"},
        "sourcePath": {"type": ["string", "null"], "minLength": 1},
        "sourceSha256": {"$ref": "#/$defs/sha256"},
        "audioPath": {"type": ["string", "null"]},
        "audioSha256": {"anyOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]},
        "lastImagePath": {"type": ["string", "null"]},
        "lastImageSha256": {"anyOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]},
        "sourceVideoPath": {"type": ["string", "null"]},
        "sourceVideoSha256": {"anyOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]},
        "retakeStartFrame": {"type": ["integer", "null"], "minimum": 0},
        "retakeEndFrame": {"type": ["integer", "null"], "minimum": 1},
        "extendFrames": {"type": ["integer", "null"], "minimum": 1},
        "extendDirection": {"enum": ["before", "after"]},
        "preserveAudio": {"type": "boolean"},
        "modelId": {"type": "string", "minLength": 1},
        "modelRevision": {"type": "string", "minLength": 1},
        "modelManifestSha256": {"$ref": "#/$defs/sha256"},
        "modelDeepVerificationFingerprint": {"$ref": "#/$defs/sha256"},
        "runtimeBinding": {"$ref": "#/$defs/runtimeBinding"},
        "runtimeBindingFingerprint": {"$ref": "#/$defs/sha256"},
        "licensePolicy": {"$ref": "#/$defs/licensePolicy"},
        "licensePolicyFingerprint": {"$ref": "#/$defs/sha256"},
        "modelFingerprint": {"$ref": "#/$defs/sha256"},
        "capabilityCohort": {"type": "string", "minLength": 1},
        "taskKind": {"type": "string", "minLength": 1},
        "prompt": {"type": "string", "minLength": 1},
        "seed": {"type": "integer"},
        "durationSeconds": {"type": "integer", "minimum": 1},
        "resolution": {"type": "string", "minLength": 1},
        "audioMode": {"enum": ["none", "source", "generated", "preserved"]},
        "commercialUse": {"type": "boolean"},
        "commercialAnnualRevenueUsd": {"type": ["integer", "null"], "minimum": 0},
        "overlaysExist": {"type": "boolean"},
        "outputPath": {"type": "string", "minLength": 1},
        "blindedCandidateId": {"type": "string", "minLength": 1},
        "queueJob": {"$ref": "#/$defs/queueJob"},
        "queueJobFingerprint": {"$ref": "#/$defs/sha256"},
        "benchmarkRecipe": {"$ref": "benchmark_recipe.v1.schema.json"},
        "benchmarkRecipeFingerprint": {"$ref": "#/$defs/sha256"},
        "analyzerRegistry": {"$ref": "analyzer_registry.v1.schema.json"},
        "analyzerRegistryFingerprint": {"$ref": "#/$defs/sha256"},
        "promotionEligible": {"type": "boolean"}
      }
    }
  }
}
