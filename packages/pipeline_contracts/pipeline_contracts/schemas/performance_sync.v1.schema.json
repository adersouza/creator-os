{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "campaign_factory.performance_sync.v1",
  "title": "Campaign Factory Performance Sync",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema",
    "campaign",
    "userId",
    "pipelineJobId",
    "pipelineTraceId",
    "summary"
  ],
  "properties": {
    "schema": {
      "const": "campaign_factory.performance_sync.v1"
    },
    "campaign": {
      "type": "string"
    },
    "userId": {
      "type": "string"
    },
    "checkedAt": {
      "type": "string"
    },
    "postsScanned": {
      "type": "integer"
    },
    "postsImported": {
      "type": "integer"
    },
    "campaignFactoryPostsScanned": {
      "type": "integer"
    },
    "metricHistoryRowsScanned": {
      "type": "integer",
      "description": "Rows read from ThreadsDashboard post_metric_history for time-series performance learning"
    },
    "metricHistoryError": {
      "type": ["string", "null"]
    },
    "historySources": {
      "type": "object",
      "additionalProperties": {"type": "integer"}
    },
    "fallbackRows": {
      "type": "integer"
    },
    "learningIneligiblePosts": {
      "type": "integer"
    },
    "learningIneligibleSnapshots": {
      "type": "integer"
    },
    "learningIneligibleReasons": {
      "type": "object",
      "additionalProperties": {"type": "integer"}
    },
    "learningLoopCutover": {
      "type": ["string", "null"]
    },
    "learningReadiness": {
      "type": "object"
    },
    "campaignFactorySnapshotsScanned": {
      "type": "integer",
      "description": "Eligible Campaign Factory performance snapshots considered after expanding post_metric_history"
    },
    "inserted": {
      "type": "integer"
    },
    "skipped": {
      "type": "integer"
    },
    "summary": {
      "type": "object"
    },
    "pipelineJobId": {
      "type": "string",
      "minLength": 1
    },
    "pipelineTraceId": {
      "type": "string",
      "minLength": 1,
      "description": "Shared trace ID propagated through the pipeline for end-to-end observability"
    }
  }
}
