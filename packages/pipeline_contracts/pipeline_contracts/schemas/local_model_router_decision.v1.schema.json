{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "reel_factory.local_model_router_decision.v1",
  "title": "Local Model Router Decision",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "decisionId", "policy", "request", "consideredCandidates", "selectedModelId", "selectedModelFingerprint", "winningEvidence", "operatorOverride", "paidProviderFallbackAllowed", "legacyLocalMotionFallbackAllowed", "decisionFingerprint"],
  "properties": {
    "schema": {"const": "reel_factory.local_model_router_decision.v1"},
    "decisionId": {"type": "string", "minLength": 1},
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version"],
      "properties": {"id": {"const": "reel_factory.local_model_router"}, "version": {"const": "1.0.0"}}
    },
    "request": {"$ref": "#/$defs/request"},
    "consideredCandidates": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/candidate"}},
    "selectedModelId": {"type": "string", "minLength": 1},
    "selectedModelFingerprint": {"$ref": "#/$defs/sha256"},
    "winningEvidence": {"$ref": "#/$defs/winningEvidence"},
    "operatorOverride": {"anyOf": [{"$ref": "#/$defs/override"}, {"type": "null"}]},
    "paidProviderFallbackAllowed": {"const": false},
    "legacyLocalMotionFallbackAllowed": {"const": false},
    "decisionFingerprint": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "nullableSha256": {"anyOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]},
    "umt5TokenizerBehavior": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema", "dependencyId", "repository", "revision", "tokenizerClass", "isFast", "fixMistralRegex", "preTokenizer", "probeCorpusSha256", "tokenIdsSha256", "aliasMatchesSnapshot", "behaviorFingerprint", "snapshotPath", "dependencyReceiptSha256", "runtimeReferencePath", "runtimeReferenceSha256", "probeScriptSha256", "isolation", "providerCalls", "productionWritesAllowed"],
      "properties": {
        "schema": {"const": "reel_factory.umt5_tokenizer_behavior.v1"},
        "dependencyId": {"type": "string", "minLength": 1},
        "repository": {"type": "string", "minLength": 1},
        "revision": {"type": "string", "minLength": 1},
        "tokenizerClass": {"const": "T5Tokenizer"},
        "isFast": {"const": true},
        "fixMistralRegex": {"type": "null"},
        "preTokenizer": {"type": "string", "minLength": 1},
        "probeCorpusSha256": {"$ref": "#/$defs/sha256"},
        "tokenIdsSha256": {"$ref": "#/$defs/sha256"},
        "aliasMatchesSnapshot": {"const": true},
        "behaviorFingerprint": {"$ref": "#/$defs/sha256"},
        "snapshotPath": {"type": "string", "minLength": 1},
        "dependencyReceiptSha256": {"$ref": "#/$defs/sha256"},
        "runtimeReferencePath": {"type": "string", "minLength": 1},
        "runtimeReferenceSha256": {"$ref": "#/$defs/sha256"},
        "probeScriptSha256": {"$ref": "#/$defs/sha256"},
        "isolation": {
          "type": "object",
          "additionalProperties": false,
          "required": ["sandboxExecutable", "sandboxExecutableSha256", "profileFingerprint", "networkDenied", "writesDenied"],
          "properties": {
            "sandboxExecutable": {"type": "string", "minLength": 1},
            "sandboxExecutableSha256": {"$ref": "#/$defs/sha256"},
            "profileFingerprint": {"$ref": "#/$defs/sha256"},
            "networkDenied": {"const": true},
            "writesDenied": {"const": true}
          }
        },
        "providerCalls": {"const": 0},
        "productionWritesAllowed": {"const": false}
      }
    },
    "runtimeBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runtimeId", "repository", "revision", "platform", "platformRelease", "osBuild", "machine", "python", "pythonExecutable", "pythonExecutableResolved", "mlxVersion", "runtimeReceiptFingerprint", "resolvedEnvironmentFingerprint", "ffmpegExecutable", "ffmpegSha256", "ffmpegSize", "ffmpegVersion", "ffprobeExecutable", "ffprobeSha256", "ffprobeSize", "ffprobeVersion"],
      "dependentRequired": {
        "umt5TokenizerBehavior": ["umt5TokenizerBehaviorFingerprint"],
        "umt5TokenizerBehaviorFingerprint": ["umt5TokenizerBehavior"]
      },
      "properties": {
        "runtimeId": {"type": "string", "minLength": 1},
        "repository": {"type": "string", "minLength": 1},
        "revision": {"type": "string", "minLength": 1},
        "platform": {"type": "string", "minLength": 1},
        "platformRelease": {"type": "string", "minLength": 1},
        "osBuild": {"type": "string", "minLength": 1},
        "machine": {"type": "string", "minLength": 1},
        "python": {"type": "string", "minLength": 1},
        "pythonExecutable": {"type": "string", "minLength": 1},
        "pythonExecutableResolved": {"type": "string", "minLength": 1},
        "mlxVersion": {"type": "string", "minLength": 1},
        "runtimeReceiptFingerprint": {"$ref": "#/$defs/sha256"},
        "resolvedEnvironmentFingerprint": {"$ref": "#/$defs/sha256"},
        "ffmpegExecutable": {"type": "string", "minLength": 1},
        "ffmpegSha256": {"$ref": "#/$defs/sha256"},
        "ffmpegSize": {"type": "integer", "minimum": 1},
        "ffmpegVersion": {"type": "string", "minLength": 1},
        "ffprobeExecutable": {"type": "string", "minLength": 1},
        "ffprobeSha256": {"$ref": "#/$defs/sha256"},
        "ffprobeSize": {"type": "integer", "minimum": 1},
        "ffprobeVersion": {"type": "string", "minLength": 1},
        "umt5TokenizerBehavior": {"$ref": "#/$defs/umt5TokenizerBehavior"},
        "umt5TokenizerBehaviorFingerprint": {"$ref": "#/$defs/sha256"}
      }
    },
    "licensePolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["licenseId", "commercialUse", "declaredAnnualRevenueUsd", "commercialRevenueLimitUsd", "commercialUseAllowed", "aiDisclosureRequired"],
      "properties": {
        "licenseId": {"type": "string", "minLength": 1},
        "commercialUse": {"type": "boolean"},
        "declaredAnnualRevenueUsd": {"type": ["integer", "null"], "minimum": 0},
        "commercialRevenueLimitUsd": {"type": ["integer", "null"], "minimum": 1},
        "commercialUseAllowed": {"const": true},
        "aiDisclosureRequired": {"type": "boolean"}
      }
    },
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["creatorId", "identityProfileId", "identityProfileFingerprint", "contentIntentId", "contentIntentFingerprint", "taskKind", "capabilityCohort", "availableMemoryBytes", "observedAt", "minimumYield", "minimumQualityScore", "maximumEvidenceAgeDays"],
      "properties": {
        "creatorId": {"enum": ["stacey", "larissa", "lola"]},
        "identityProfileId": {"type": "string", "minLength": 1},
        "identityProfileFingerprint": {"$ref": "#/$defs/sha256"},
        "contentIntentId": {"type": "string", "minLength": 1},
        "contentIntentFingerprint": {"$ref": "#/$defs/sha256"},
        "taskKind": {"type": "string", "minLength": 1},
        "capabilityCohort": {"type": "string", "minLength": 1},
        "availableMemoryBytes": {"type": "integer", "minimum": 1},
        "observedAt": {"type": "string", "format": "date-time"},
        "minimumYield": {"type": "number", "minimum": 0.5, "maximum": 1},
        "minimumQualityScore": {"type": "number", "minimum": 0.6, "maximum": 1},
        "maximumEvidenceAgeDays": {"type": "integer", "minimum": 1, "maximum": 30}
      }
    },
    "measurements": {
      "type": "object",
      "additionalProperties": false,
      "required": ["promotionEligibleYield", "meanHumanQualityScore", "medianWallTimeSeconds", "medianPeakMemoryBytes"],
      "properties": {
        "promotionEligibleYield": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
        "meanHumanQualityScore": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
        "medianWallTimeSeconds": {"type": ["number", "null"], "exclusiveMinimum": 0},
        "medianPeakMemoryBytes": {"type": ["integer", "null"], "minimum": 1}
      }
    },
    "promotionApproval": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evaluationId", "approvalEventId", "approvalEventHash", "approvedAt", "approvedBy", "scope", "expiresAt", "candidateModelFingerprint", "taskKind", "candidateBenchmarkIds", "hardwareFingerprint", "evidenceFingerprint"],
      "properties": {
        "evaluationId": {"type": "string", "minLength": 1},
        "approvalEventId": {"type": "string", "minLength": 1},
        "approvalEventHash": {"$ref": "#/$defs/sha256"},
        "approvedAt": {"type": "string", "format": "date-time"},
        "approvedBy": {"type": "string", "minLength": 1},
        "scope": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "expiresAt": {"type": ["string", "null"], "format": "date-time"},
        "candidateModelFingerprint": {"$ref": "#/$defs/sha256"},
        "taskKind": {"type": "string", "minLength": 1},
        "candidateBenchmarkIds": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "hardwareFingerprint": {"$ref": "#/$defs/sha256"},
        "evidenceFingerprint": {"$ref": "#/$defs/sha256"}
      }
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["modelId", "modelFingerprint", "capabilityCohort", "requiredMemoryBytes", "benchmarkIds", "matchedArenaSampleIds", "validArenaSampleIds", "arenaSummaryFingerprint", "runtimeBinding", "runtimeBindingFingerprint", "licensePolicy", "licensePolicyFingerprint", "promotionApproval", "measurements", "score", "exclusions"],
      "properties": {
        "modelId": {"type": "string", "minLength": 1},
        "modelFingerprint": {"$ref": "#/$defs/nullableSha256"},
        "capabilityCohort": {"type": "string", "minLength": 1},
        "requiredMemoryBytes": {"type": ["integer", "null"], "minimum": 1},
        "benchmarkIds": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "matchedArenaSampleIds": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "validArenaSampleIds": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "arenaSummaryFingerprint": {"$ref": "#/$defs/sha256"},
        "runtimeBinding": {"anyOf": [{"$ref": "#/$defs/runtimeBinding"}, {"type": "null"}]},
        "runtimeBindingFingerprint": {"$ref": "#/$defs/nullableSha256"},
        "licensePolicy": {"anyOf": [{"$ref": "#/$defs/licensePolicy"}, {"type": "null"}]},
        "licensePolicyFingerprint": {"$ref": "#/$defs/nullableSha256"},
        "promotionApproval": {"anyOf": [{"$ref": "#/$defs/promotionApproval"}, {"type": "null"}]},
        "measurements": {"$ref": "#/$defs/measurements"},
        "score": {"type": ["number", "null"]},
        "exclusions": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
      }
    },
    "cohortKey": {
      "type": "object",
      "additionalProperties": false,
      "required": ["creatorId", "identityProfileId", "identityProfileFingerprint", "contentIntentId", "contentIntentFingerprint", "taskKind", "capabilityCohort"],
      "properties": {
        "creatorId": {"enum": ["stacey", "larissa", "lola"]},
        "identityProfileId": {"type": "string", "minLength": 1},
        "identityProfileFingerprint": {"$ref": "#/$defs/sha256"},
        "contentIntentId": {"type": "string", "minLength": 1},
        "contentIntentFingerprint": {"$ref": "#/$defs/sha256"},
        "taskKind": {"type": "string", "minLength": 1},
        "capabilityCohort": {"type": "string", "minLength": 1}
      }
    },
    "winningEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["arenaSummaryFingerprint", "benchmarkIds", "cohortKey", "matchedArenaSampleIds", "validArenaSampleIds", "runtimeBinding", "runtimeBindingFingerprint", "licensePolicy", "licensePolicyFingerprint", "measurements", "promotionApproval", "score"],
      "properties": {
        "arenaSummaryFingerprint": {"$ref": "#/$defs/sha256"},
        "benchmarkIds": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "cohortKey": {"$ref": "#/$defs/cohortKey"},
        "matchedArenaSampleIds": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "validArenaSampleIds": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "runtimeBinding": {"$ref": "#/$defs/runtimeBinding"},
        "runtimeBindingFingerprint": {"$ref": "#/$defs/sha256"},
        "licensePolicy": {"$ref": "#/$defs/licensePolicy"},
        "licensePolicyFingerprint": {"$ref": "#/$defs/sha256"},
        "measurements": {"$ref": "#/$defs/measurements"},
        "promotionApproval": {"$ref": "#/$defs/promotionApproval"},
        "score": {"type": "number"}
      }
    },
    "override": {
      "type": "object",
      "additionalProperties": false,
      "required": ["modelId", "operator", "reason", "excludedFromBenchmarkLearning"],
      "properties": {
        "modelId": {"type": "string", "minLength": 1},
        "operator": {"type": "string", "minLength": 1},
        "reason": {"type": "string", "minLength": 1},
        "excludedFromBenchmarkLearning": {"const": true}
      }
    }
  }
}
