{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "reel_factory.local_model_router_decision.v1",
  "title": "Local Model Router Decision",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "decisionId", "policy", "request", "consideredCandidates", "selectedModelId", "selectedModelFingerprint", "winningEvidence", "operatorOverride", "paidProviderFallbackAllowed", "legacyLocalMotionFallbackAllowed", "decisionFingerprint"],
  "properties": {
    "schema": {"const": "reel_factory.local_model_router_decision.v1"},
    "decisionId": {"type": "string", "minLength": 1},
    "policy": {"type": "object", "required": ["id", "version"], "properties": {"id": {"const": "reel_factory.local_model_router"}, "version": {"const": "1.0.0"}}, "additionalProperties": false},
    "request": {"type": "object"},
    "consideredCandidates": {"type": "array", "minItems": 1, "items": {"type": "object"}},
    "selectedModelId": {"type": "string", "minLength": 1},
    "selectedModelFingerprint": {"$ref": "#/$defs/sha256"},
    "winningEvidence": {"type": "object"},
    "operatorOverride": {"type": ["object", "null"]},
    "paidProviderFallbackAllowed": {"const": false},
    "legacyLocalMotionFallbackAllowed": {"const": false},
    "decisionFingerprint": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {"sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}}
}
