{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://creator-os.local/schemas/human_media_review.v1.schema.json",
  "title": "Human Media Review V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "reviewId",
    "arenaPlanId",
    "sampleId",
    "blindedCandidateId",
    "subjectSha256",
    "sourceSha256",
    "reviewer",
    "reviewedAt",
    "rubricVersion",
    "ratings",
    "decisions",
    "provenance",
    "reviewFingerprint"
  ],
  "properties": {
    "schema": { "const": "reel_factory.human_media_review.v1" },
    "reviewId": { "type": "string", "minLength": 1 },
    "arenaPlanId": { "type": "string", "minLength": 1 },
    "sampleId": { "type": "string", "minLength": 1 },
    "blindedCandidateId": { "type": "string", "minLength": 1 },
    "subjectSha256": { "$ref": "#/$defs/sha256" },
    "sourceSha256": { "$ref": "#/$defs/sha256" },
    "reviewer": { "type": "string", "minLength": 1 },
    "reviewedAt": { "type": "string", "format": "date-time" },
    "rubricVersion": { "type": "string", "minLength": 1 },
    "ratings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "realism",
        "attractiveness",
        "creatorIdentitySimilarity",
        "faceStability",
        "motionNaturalness",
        "faceArtifactScore",
        "handsVisible",
        "handArtifactScore",
        "bodyArtifactScore",
        "conversionUsefulness",
        "intentAdherence",
        "loopAcceptable"
      ],
      "properties": {
        "realism": { "$ref": "#/$defs/score" },
        "attractiveness": { "$ref": "#/$defs/score" },
        "creatorIdentitySimilarity": { "$ref": "#/$defs/score" },
        "faceStability": { "$ref": "#/$defs/score" },
        "motionNaturalness": { "$ref": "#/$defs/score" },
        "faceArtifactScore": { "$ref": "#/$defs/score" },
        "handsVisible": { "type": "boolean" },
        "handArtifactScore": {
          "oneOf": [
            { "$ref": "#/$defs/score" },
            { "type": "null" }
          ]
        },
        "bodyArtifactScore": { "$ref": "#/$defs/score" },
        "conversionUsefulness": { "$ref": "#/$defs/score" },
        "intentAdherence": { "$ref": "#/$defs/score" },
        "loopAcceptable": { "type": "boolean" }
      }
    },
    "decisions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "creatorIdentityPreserved",
        "anatomyAcceptable",
        "operatorUseful",
        "approvedForBenchmark"
      ],
      "properties": {
        "creatorIdentityPreserved": { "type": "boolean" },
        "anatomyAcceptable": { "type": "boolean" },
        "operatorUseful": { "type": "boolean" },
        "approvedForBenchmark": { "type": "boolean" }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reviewMode", "unblindingReason", "sourceReferences"],
      "properties": {
        "reviewMode": { "enum": ["blinded", "unblinded"] },
        "unblindingReason": { "type": ["string", "null"] },
        "sourceReferences": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["recordId", "fingerprint"],
            "properties": {
              "recordId": { "type": "string", "minLength": 1 },
              "fingerprint": { "$ref": "#/$defs/sha256" }
            }
          }
        }
      }
    },
    "reviewFingerprint": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  }
}
