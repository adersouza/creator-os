{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "reel_factory.local_model_arena_review_packet.v1",
  "title": "Local Model Arena Blinded Review Packet",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "packetId", "arenaPlanId", "arenaPlanFingerprint", "createdAt", "expectedCandidateCount", "candidates", "providerCalls", "productionWrites", "producerAttestation", "packetFingerprint"],
  "properties": {
    "schema": {"const": "reel_factory.local_model_arena_review_packet.v1"},
    "packetId": {"type": "string", "minLength": 1},
    "arenaPlanId": {"type": "string", "minLength": 1},
    "arenaPlanFingerprint": {"$ref": "#/$defs/sha256"},
    "createdAt": {"type": "string", "format": "date-time"},
    "expectedCandidateCount": {"type": "integer", "minimum": 1},
    "candidates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["reviewOrdinal", "blindedCandidateId", "creatorId", "contentIntentId", "subjectPath", "subjectSha256"],
        "properties": {
          "reviewOrdinal": {"type": "integer", "minimum": 1},
          "blindedCandidateId": {"type": "string", "minLength": 1},
          "creatorId": {"enum": ["stacey", "larissa", "lola"]},
          "contentIntentId": {"type": "string", "minLength": 1},
          "subjectPath": {"type": "string", "minLength": 1},
          "subjectSha256": {"$ref": "#/$defs/sha256"}
        }
      }
    },
    "providerCalls": {"const": 0},
    "productionWrites": {"const": 0},
    "producerAttestation": {"$ref": "evidence_attestation.v1.schema.json"},
    "packetFingerprint": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
  }
}
