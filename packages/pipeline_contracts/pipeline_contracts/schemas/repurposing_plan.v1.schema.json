{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "campaign_factory.repurposing_plan.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "master_asset_id",
    "preset_name",
    "target_count",
    "platform"
  ],
  "properties": {
    "schema": {
      "const": "campaign_factory.repurposing_plan.v1"
    },
    "master_asset_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "preset_name": {
      "type": "string",
      "enum": ["tiktok_aggressive", "ig_subtle", "custom"]
    },
    "target_count": {
      "type": "integer",
      "minimum": 1,
      "maximum": 500
    },
    "platform": {
      "type": "string"
    },
    "custom_config": {
      "type": "object",
      "description": "Overrides for the RepurposeConfig if preset_name is custom"
    }
  }
}
