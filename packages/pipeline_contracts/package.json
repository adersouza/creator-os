{
  "name": "@creator-os/pipeline-contracts",
  "version": "2.1.0",
  "description": "Versioned Creator OS pipeline schemas and TypeScript validators",
  "type": "module",
  "files": [
    "dist",
    "contract-manifest.json",
    "pipeline_contracts/schemas"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "prepack": "pnpm run build"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./contract-manifest.json": "./contract-manifest.json",
    "./schemas/*": "./pipeline_contracts/schemas/*"
  },
  "dependencies": {
    "ajv": "^8.18.0"
  },
  "devDependencies": {
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
