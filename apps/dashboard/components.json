{
  "$schema": "https://ui.shadcn.com/schema.json",
  "style": "nova",
  "rsc": false,
  "tsx": true,
  "tailwind": {
    "config": "",
    "css": "src/index.css",
    "baseColor": "zinc",
    "cssVariables": true,
    "prefix": ""
  },
  "iconLibrary": "lucide",
  "rtl": false,
  "aliases": {
    "components": "@/src/components",
    "utils": "@/src/lib/utils",
    "ui": "@/src/components/shadcn",
    "lib": "@/src/lib",
    "hooks": "@/src/hooks"
  },
  "menuColor": "default",
  "menuAccent": "subtle",
  "registries": {
    "@uitripled": {
      "url": "https://ui.tripled.work/r/{name}.json"
    },
    "@kibo-ui": {
      "url": "https://www.kibo-ui.com/r/{name}.json"
    },
    "@magicui": {
      "url": "https://magicui.design/r/{name}.json"
    },
    "@motion-primitives": {
      "url": "https://motion-primitives.com/r/{name}.json"
    },
    "@blocks-so": {
      "url": "https://blocks.so/r/{name}.json"
    }
  }
}
