{
	"compilerOptions": {
		"target": "ES2022",
		"module": "Node16",
		"moduleResolution": "node16",
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"strict": true,
		"skipLibCheck": true,
		"types": ["node"],
		"declaration": false,
		"outDir": "../.vercel/output/functions",
		"ignoreDeprecations": "6.0",
		"rootDir": "..",
		"baseUrl": ".",
		"paths": {
			"zod": ["../node_modules/zod/v3/index.d.ts"],
			"zod/v4/core": ["./types/zod-v4-core.d.ts"],
			"zod/v4": ["../node_modules/zod/v3/index.d.ts"],
			"zod/v4/*": ["../node_modules/zod/v3/*"],
			"zod/*": ["../node_modules/zod/v3/*"],
			"@/src/*": ["../src/*.ts", "../src/*"],
			"@/services/ai": ["../src/services/ai/index.ts", "../services/ai/index.ts"],
			"@/services/*": ["../src/services/*.ts", "../services/*.ts", "../src/services/*", "../services/*"],
			"@/types/*": ["../src/types/*.ts", "../types/*.ts", "../src/types/*", "../types/*"],
			"@/utils/*": ["../src/utils/*.ts", "../utils/*.ts", "../src/utils/*", "../utils/*"],
			"@/*": ["../src/*.ts", "../*.ts", "../src/*", "../*"]
		}
	},
	"include": ["./**/*.ts", "../types/**/*.ts"],
	"exclude": ["node_modules", "**/*.test.ts", "**/__tests__/**"]
}
