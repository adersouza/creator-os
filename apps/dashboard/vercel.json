  "rewrites": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "(?!juno33\\.com$)(?!localhost$)(?!.*\\.vercel\\.app$).*\\..*"
        }
      ],
      "destination": "/api/link-page/domain"
    },
    {
      "source": "/go/convert",
      "destination": "/api/go/convert"
    },
    {
      "source": "/go/r/:redirectId",
      "destination": "/api/go/r/:redirectId"
    },
    {
      "source": "/go/:code",
      "destination": "/api/go/:code"
    },
    {
      "source": "/@:slug",
