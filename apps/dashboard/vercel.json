    "api/cron/sync-orchestrator.ts": {
      "maxDuration": 180
    },
    "api/cron/publish-worker.ts": {
      "maxDuration": 180
    },
    "api/cron/campaign-schedule-recovery.ts": {
      "maxDuration": 120
    },
    "api/cron/scheduler.ts": {
      "maxDuration": 180
    },
    "api/trends.ts": {
      "maxDuration": 120
    },
    "api/ai.ts": {
      "maxDuration": 120
    },
    "api/competitors.ts": {
      "maxDuration": 120
    },
    "api/instagram.ts": {
      "maxDuration": 30
    },
    "api/recap.ts": {
      "maxDuration": 30
    },
    "api/v1.ts": {
      "maxDuration": 30
    },
    "api/jobs.ts": {
      "maxDuration": 300
