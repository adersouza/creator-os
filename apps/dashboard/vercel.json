    "api/threads/webhook-subscribe.ts": {
      "maxDuration": 30
    },
    "api/auto-post-publish.ts": {
      "maxDuration": 300
    },
    "api/cross-reply-publish.ts": {
      "maxDuration": 30
    },
    "api/scheduled-post-publish.ts": {
      "maxDuration": 300
    },
    "api/queue-fill.ts": {
      "maxDuration": 120
    },
    "api/user.ts": {
      "maxDuration": 120
    },
    "api/webhook.ts": {
      "maxDuration": 30
    },
    "api/meta/process-deletion.ts": {
      "maxDuration": 300
    },
    "api/cron/analytics-pipeline.ts": {
      "maxDuration": 300
    },
    "api/cron/daily-orchestrator.ts": {
      "maxDuration": 300
    },
    "api/cron/health-monitor.ts": {
      "maxDuration": 300
    },
    "api/cron/six-hour-pipeline.ts": {
      "maxDuration": 300
    },
    "api/cron/weekly-reports.ts": {
      "maxDuration": 300
    },
    "api/cron/cost-digest.ts": {
      "maxDuration": 120
    },
    "api/cron/monthly-kpi.ts": {
      "maxDuration": 300
    },
    "api/cron/trend-scanner.ts": {
      "maxDuration": 300
    },
    "api/cron/auto-learning.ts": {
      "maxDuration": 300
    },
    "api/cron/daily-orchestrator-late.ts": {
      "maxDuration": 300
    },
    "api/cron/auto-reply-worker.ts": {
      "maxDuration": 120
    },
    "api/cron/inbox-suggestions.ts": {
      "maxDuration": 120
    },
    "api/cron/reply-farming-worker.ts": {
      "maxDuration": 120
    },
    "api/cron/cta-reply-worker.ts": {
      "maxDuration": 120
    },
    "api/cron/overnight-brief.ts": {
      "maxDuration": 300
    },
    "api/cron/originality-capture.ts": {
      "maxDuration": 300
    }
