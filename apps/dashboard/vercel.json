{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd mcp-server && npm ci && npm run build && cd .. && npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "git": {
    "deploymentEnabled": {
      "main": true,
      "staging": true
    }
  },
  "env": {
    "NODE_OPTIONS": "--disable-warning=DEP0169"
  },
  "crons": [
    {
      "path": "/api/cron/webhook-processor",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/cron/publish-worker",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/campaign-schedule-recovery",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/sync-orchestrator",
      "schedule": "2,17,32,47 * * * *"
    },
    {
      "path": "/api/cron/analytics-pipeline",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/daily-orchestrator",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/health-monitor",
      "schedule": "0 */4 * * *"
    },
    {
      "path": "/api/cron/six-hour-pipeline",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/weekly-reports",
      "schedule": "0 8 * * 1"
    },
    {
      "path": "/api/cron/cost-digest",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/monthly-kpi",
      "schedule": "0 8 1 * *"
    },
    {
      "path": "/api/cron/trend-scanner",
      "schedule": "0 */2 * * *"
    },
    {
      "path": "/api/cron/auto-learning",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/autoposter-watchdog",
      "schedule": "15,45 * * * *"
    },
    {
      "path": "/api/cron/autoposter-doctor",
      "schedule": "25 * * * *"
    },
    {
      "path": "/api/cron/daily-orchestrator-late",
      "schedule": "30 1 * * *"
    },
    {
      "path": "/api/cron/auto-reply-worker",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/inbox-suggestions",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/reply-farming-worker",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/dawn-planner",
      "schedule": "5 */4 * * *"
    },
    {
      "path": "/api/cron/account-state-evaluator",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/cta-reply-worker",
      "schedule": "10,40 * * * *"
    },
    {
      "path": "/api/cron/scheduler",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/reconcile-daily",
      "schedule": "30 3 * * *"
    },
    {
      "path": "/api/cron/overnight-brief",
      "schedule": "55 1 * * *"
    },
    {
      "path": "/api/cron/originality-capture",
      "schedule": "17 3 * * *"
    }
  ],
  "functions": {
    "api/cron/webhook-processor.ts": {
      "maxDuration": 120
    },
    "api/cron/reconcile-daily.ts": {
      "maxDuration": 300
    },
    "api/cron/autoposter-watchdog.ts": {
      "maxDuration": 300
    },
    "api/cron/autoposter-doctor.ts": {
